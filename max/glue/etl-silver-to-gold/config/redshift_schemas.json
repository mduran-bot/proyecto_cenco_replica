      "fields": {
        "order_item_id": {
          "type": "VARCHAR(50)",
          "nullable": false,
          "description": "ID único del item"
        },
        "order_id": {
          "type": "VARCHAR(50)",
          "nullable": false,
          "description": "ID de la orden padre"
        },
        "product_id": {
          "type": "VARCHAR(50)",
          "nullable": false,
          "description": "ID del producto"
        },
        "sku": {
          "type": "VARCHAR(100)",
          "nullable": false,
          "description": "SKU del producto"
        },
        "quantity": {
          "type": "INTEGER",
          "nullable": false,
          "description": "Cantidad solicitada"
        },
        "picked_quantity": {
          "type": "INTEGER",
          "nullable": true,
          "description": "Cantidad pickeada"
        },
        "unit_price": {
          "type": "DECIMAL(18,2)",
          "nullable": false,
          "description": "Precio unitario"
        },
        "total_price": {
          "type": "DECIMAL(18,2)",
          "nullable": false,
          "description": "Precio total del item"
        },
        "status": {
          "type": "VARCHAR(50)",
          "nullable": false,
          "description": "Estado del item"
        },
        "date_created": {
          "type": "TIMESTAMP",
          "nullable": false,
          "description": "Fecha de creación"
        },
        "date_modified": {
          "type": "TIMESTAMP",
          "nullable": true,
          "description": "Fecha de modificación"
        },
        "quantity_difference": {
          "type": "INTEGER",
          "nullable": true,
          "description": "Diferencia entre cantidad solicitada y pickeada",
          "calculated": true,
          "formula": "quantity - picked_quantity"
        }
      },
      "quality_rules": {
        "critical_fields": [
          "order_item_id",
          "order_id",
          "product_id",
          "quantity"
        ],
        "numeric_ranges": {
          "quantity": {
            "min": 0,
            "max": 999999
