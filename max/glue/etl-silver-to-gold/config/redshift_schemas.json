{
  "_comment": "Esquemas de tablas Gold (Redshift) con campos calculados y validaciones",
  "_description": "Define la estructura completa de cada tabla en la capa Gold",
  "tables": {
    "wms_orders": {
      "description": "Órdenes de WMS procesadas y enriquecidas",
      "source_tables": [
        "metro_orders_clean"
      ],
      "primary_key": [
        "order_id"
      ],
      "partition_by": [
        "date_created"
      ],
      "fields": {
        "order_id": {
          "type": "VARCHAR(50)",
          "nullable": false,
          "description": "ID único de la orden"
        },
        "order_group_id": {
          "type": "VARCHAR(50)",
          "nullable": true,
          "description": "ID del grupo de órdenes"
        },
        "commerce_sequential_id": {
          "type": "VARCHAR(50)",
          "nullable": true,
          "description": "ID secuencial del comercio"
        },
        "commerce_date_created": {
          "type": "TIMESTAMP",
          "nullable": true,
          "description": "Fecha de creación en el comercio"
        },
        "commerce_sales_channel": {
          "type": "VARCHAR(50)",
          "nullable": true,
          "description": "Canal de ventas del comercio"
        },
        "total_amount": {
          "type": "DECIMAL(18,2)",
          "nullable": false,
          "description": "Monto total de la orden"
        },
        "commerce_id": {
          "type": "VARCHAR(100)",
          "nullable": true,
          "description": "ID del comercio"
        },
        "status": {
          "type": "VARCHAR(50)",
          "nullable": false,
          "description": "Estado de la orden"
        },
        "original_amount": {
          "type": "DECIMAL(18,2)",
          "nullable": true,
          "description": "Monto original antes de cambios"
        },
        "raw_total_amount": {
          "type": "DECIMAL(18,2)",
          "nullable": true,
          "description": "Monto total sin procesar"
        },
        "currency": {
          "type": "VARCHAR(10)",
          "nullable": false,
          "description": "Moneda de la transacción"
        },
        "sales_channel_name": {
          "type": "VARCHAR(100)",
          "nullable": true,
          "description": "Nombre del canal de ventas"
        },
        "account_name": {
          "type": "VARCHAR(100)",
          "nullable": true,
          "description": "Nombre de la cuenta"
        },
        "account_platform": {
          "type": "VARCHAR(50)",
          "nullable": true,
          "description": "Plataforma de la cuenta (vtex, etc)"
        },
        "seller_name": {
          "type": "VARCHAR(100)",
          "nullable": true,
          "description": "Nombre del vendedor"
        },
        "date_created": {
          "type": "TIMESTAMP",
          "nullable": false,
          "description": "Fecha de creación del registro"
        },
        "date_modified": {
          "type": "TIMESTAMP",
          "nullable": true,
          "description": "Fecha de última modificación"
        },
        "total_changes": {
          "type": "DECIMAL(18,2)",
          "nullable": true,
          "description": "Diferencia entre monto total y monto original",
          "calculated": true,
          "formula": "total_amount - original_amount"
        }
      },
      "quality_rules": {
        "critical_fields": [
          "order_id",
          "status",
          "total_amount",
          "date_created"
        ],
        "valid_statuses": [
          "pending",
          "processing",
          "readyForDelivery",
          "delivered",
          "cancelled"
        ],
        "numeric_ranges": {
          "total_amount": {
            "min": 0,
            "max": 999999
          }
        }
      }
    },
