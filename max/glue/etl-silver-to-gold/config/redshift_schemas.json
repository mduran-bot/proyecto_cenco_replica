        "date_modified": {
          "type": "TIMESTAMP",
          "nullable": true,
          "description": "Fecha de modificación"
        }
      },
      "quality_rules": {
        "critical_fields": [
          "product_id",
          "product_name",
          "sku",
          "price"
        ],
        "numeric_ranges": {
          "price": {
            "min": 0,
            "max": 999999
          }
        }
      }
    },
