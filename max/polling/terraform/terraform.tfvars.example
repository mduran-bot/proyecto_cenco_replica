# ============================================================================
# API Polling System - Example Configuration
# ============================================================================
# Copy this file to terraform.tfvars and customize for your environment
# ============================================================================

# AWS Configuration
aws_region = "us-east-1"
# aws_access_key_id     = "your-access-key"     # Pass via environment variable
# aws_secret_access_key = "your-secret-key"     # Pass via environment variable
# aws_session_token     = "your-session-token"  # Optional, for STS

# Project Configuration
environment  = "dev"
project_name = "janis-polling"

# DynamoDB Configuration
dynamodb_billing_mode         = "PAY_PER_REQUEST"
enable_point_in_time_recovery = true

# S3 Configuration
enable_s3_versioning        = true
s3_intelligent_tiering_days = 30
s3_glacier_transition_days  = 90
s3_expiration_days          = 365

# SNS Configuration
error_notification_emails = [
  "data-team@example.com",
  "ops-team@example.com"
]

# MWAA Configuration
mwaa_environment_arn = "arn:aws:airflow:us-east-1:123456789012:environment/janis-mwaa-dev"

# Secrets Manager Configuration
secrets_manager_arns = [
  "arn:aws:secretsmanager:us-east-1:123456789012:secret:janis-api-key-xxxxx"
]

# Monitoring Configuration
enable_monitoring   = true
log_retention_days  = 30
