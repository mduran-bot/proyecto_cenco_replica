{
  "apis": {
    "orders": {
      "endpoint": "order",
      "base_url": "https://oms.janis.in/api",
      "schedule": "rate(5 minutes)",
      "priority": "high",
      "tables": ["wms_orders", "wms_order_items", "wms_order_item_weighables", "wms_order_payments", "wms_order_payments_connector_responses", "wms_order_custom_data_fields", "invoices"]
    },
    "picking_sessions": {
      "endpoint": "session",
      "base_url": "https://picking.janis.in/api",
      "schedule": "rate(5 minutes)",
      "priority": "high",
      "tables": ["wms_order_picking"]
    },
    "order_history": {
      "endpoint": "order/{id}/history",
      "base_url": "https://oms.janis.in/api",
      "schedule": "rate(5 minutes)",
      "priority": "high",
      "tables": ["wms_order_status_changes"]
    },
    "shipping": {
      "endpoint": "shipping",
      "base_url": "https://delivery.janis.in/api",
      "schedule": "rate(5 minutes)",
      "priority": "high",
      "tables": ["wms_order_shipping"]
    },
    "stock": {
      "endpoint": "stock",
      "base_url": "https://wms.janis.in/api",
      "schedule": "rate(10 minutes)",
      "priority": "high",
      "tables": ["stock"]
    },
    "prices": {
      "endpoint": "price",
      "base_url": "https://pricing.janis.in/api",
      "schedule": "rate(30 minutes)",
      "priority": "medium",
      "tables": ["price"]
    },
    "sc_sku_prices": {
      "endpoint": "sc-sku-price",
      "base_url": "https://pricing.janis.in/api",
      "schedule": "rate(30 minutes)",
      "priority": "medium",
      "tables": ["price"]
    },
    "products": {
      "endpoint": "product",
      "base_url": "https://catalog.janis.in/api",
      "schedule": "rate(1 hour)",
      "priority": "medium",
      "tables": ["products"]
    },
    "skus": {
      "endpoint": "sku",
      "base_url": "https://catalog.janis.in/api",
      "schedule": "rate(1 hour)",
      "priority": "medium",
      "tables": ["skus"]
    },
    "categories": {
      "endpoint": "category",
      "base_url": "https://catalog.janis.in/api",
      "schedule": "rate(1 hour)",
      "priority": "low",
      "tables": ["categories"]
    },
    "brands": {
      "endpoint": "brand",
      "base_url": "https://catalog.janis.in/api",
      "schedule": "rate(1 hour)",
      "priority": "low",
      "tables": ["brands"]
    },
    "stores": {
      "endpoint": "stores",
      "base_url": "https://commerce.janis.in/api",
      "schedule": "rate(24 hours)",
      "priority": "low",
      "tables": ["wms_stores"]
    },
    "carriers": {
      "endpoint": "carrier",
      "base_url": "https://delivery.janis.in/api",
      "schedule": "rate(24 hours)",
      "priority": "low",
      "tables": ["wms_logistic_carriers"]
    },
    "delivery_planning": {
      "endpoint": "route-planning",
      "base_url": "https://tms.janis.in/api",
      "schedule": "rate(24 hours)",
      "priority": "low",
      "tables": ["wms_logistic_delivery_planning"]
    },
    "delivery_ranges": {
      "endpoint": "time-slot",
      "base_url": "https://delivery.janis.in/api",
      "schedule": "rate(24 hours)",
      "priority": "low",
      "tables": ["wms_logistic_delivery_ranges"]
    }
  },
  "rate_limiting": {
    "max_requests_per_minute": 100,
    "backoff_factor": 2,
    "max_retries": 3
  },
  "pagination": {
    "page_size": 100,
    "max_pages": 1000
  }
}
