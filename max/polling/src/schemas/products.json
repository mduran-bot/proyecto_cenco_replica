{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "products",
  "title": "Product",
  "description": "Schema de validación para productos del Catalog Service de Janis",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Identificador único del producto",
      "example": "3d1fc1eeb5b68406e0487a06"
    },
    "name": {
      "type": "string",
      "description": "Nombre del producto",
      "example": "Some Product"
    },
    "referenceId": {
      "type": "string",
      "description": "ID de referencia del producto",
      "example": "ref-prod-1"
    },
    "brand": {
      "type": "string",
      "description": "ID de la marca (referencia a Brand entity)",
      "example": "3d1fc1eeb5b68406e0487a06"
    },
    "category": {
      "type": "string",
      "description": "ID de la categoría principal (referencia a Category entity)",
      "example": "2d1fc1eeb5b68406e0487a06"
    },
    "status": {
      "type": "string",
      "description": "Estado del producto",
      "enum": ["active", "inactive"],
      "example": "active"
    },
    "commerceId": {
      "type": ["string", "null"],
      "description": "ID del producto en la plataforma de comercio",
      "example": "12345"
    },
    "title": {
      "type": ["string", "null"],
      "description": "Título del producto",
      "example": "Some Product Title"
    },
    "description": {
      "type": ["string", "null"],
      "description": "Descripción del producto",
      "example": "Some Product Description"
    },
    "shortDescription": {
      "type": ["string", "null"],
      "description": "Descripción corta del producto",
      "example": "Some Product short description"
    },
    "keywords": {
      "type": "array",
      "description": "Palabras clave del producto",
      "items": {
        "type": "string"
      }
    },
    "categoriesIds": {
      "type": "array",
      "description": "IDs del árbol de categorías",
      "readOnly": true,
      "items": {
        "type": "string"
      }
    },
    "salesChannels": {
      "type": "array",
      "description": "IDs de canales de venta asociados al producto",
      "items": {
        "type": "string"
      }
    },
    "slug": {
      "type": ["string", "null"],
      "description": "Slug del producto (URL friendly)",
      "example": "some-product"
    },
    "skus": {
      "type": "array",
      "description": "SKUs asociados al producto",
      "readOnly": true,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID del SKU"
          },
          "name": {
            "type": "string",
            "description": "Nombre del SKU"
          },
          "referenceId": {
            "type": "string",
            "description": "ID de referencia del SKU"
          },
          "eans": {
            "type": "array",
            "items": { "type": "string" },
            "description": "EANs del SKU"
          },
          "sellingMeasurementUnit": {
            "type": ["string", "null"],
            "description": "Unidad de medida de venta"
          },
          "sellingUnitMultiplier": {
            "type": ["number", "null"],
            "description": "Multiplicador de unidad de venta"
          }
        }
      }
    },
    "isNew": {
      "type": ["boolean", "null"],
      "description": "Indica si el producto es nuevo",
      "example": true
    },
    "releaseDate": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Fecha de lanzamiento del producto"
    },
    "taxCode": {
      "type": ["string", "null"],
      "description": "Código impositivo del producto",
      "example": "abc-123"
    },
    "dateCreated": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de creación del producto"
    },
    "dateModified": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de última modificación del producto"
    }
  },
  "required": [
    "id",
    "name",
    "referenceId",
    "brand",
    "category",
    "status",
    "dateCreated",
    "dateModified"
  ],
  "additionalProperties": true
}
