{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "orders",
  "title": "Order",
  "description": "Schema de validación para órdenes del OMS de Janis",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Identificador único de la orden",
      "example": "631fb04c8fe08f51a8ee5949"
    },
    "status": {
      "type": "string",
      "description": "Estado actual de la orden",
      "enum": [
        "new",
        "inAudit",
        "readyForPicking",
        "picking",
        "readyToProcessPicking",
        "processingPicking",
        "picked",
        "processingPromotions",
        "inPostPickingAudit",
        "pickingRejected",
        "readyForInvoice",
        "capturingPayments",
        "invoiced",
        "preparingInternalDistribution",
        "readyForInternalDistribution",
        "fulfillingInternalDistribution",
        "needsRepacking",
        "processingRepacking",
        "validatingPayments",
        "readyForDelivery",
        "inDelivery",
        "delivered",
        "partiallyDelivered",
        "needsRescheduling",
        "cancelationRequested",
        "canceled",
        "pendingCandidatesConfirmation",
        "pendingCandidatesApproval",
        "pendingCandidatesValidation",
        "candidatesConfirmationDeadlineExceeded"
      ]
    },
    "totalAmount": {
      "type": "number",
      "description": "Monto total de la orden",
      "example": 78.5
    },
    "currency": {
      "type": ["string", "null"],
      "description": "Código ISO3 de la moneda",
      "example": "ARS"
    },
    "commerceId": {
      "type": "string",
      "description": "ID de la orden en la plataforma de comercio",
      "example": "4354534545-01"
    },
    "salesChannelId": {
      "type": "string",
      "description": "ID del canal de ventas",
      "example": "e555345345345as67a342a"
    },
    "items": {
      "type": "array",
      "description": "Ítems de la orden",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": ["string", "null"],
            "description": "ID del ítem"
          },
          "name": {
            "type": ["string", "null"],
            "description": "Nombre del ítem"
          },
          "purchasedPrice": {
            "type": "number",
            "description": "Precio de compra del ítem",
            "example": 78.5
          },
          "purchasedQuantity": {
            "type": "number",
            "description": "Cantidad comprada",
            "example": 2
          },
          "ean": {
            "type": ["string", "null"],
            "description": "EAN del ítem"
          },
          "commerceSkuId": {
            "type": ["string", "null"],
            "description": "ID del SKU en la plataforma de comercio"
          }
        },
        "required": ["purchasedPrice", "purchasedQuantity"]
      }
    },
    "customer": {
      "type": "object",
      "description": "Cliente de la orden",
      "properties": {
        "email": {
          "type": ["string", "null"],
          "description": "Email del cliente"
        },
        "firstName": {
          "type": ["string", "null"],
          "description": "Nombre del cliente"
        },
        "lastName": {
          "type": ["string", "null"],
          "description": "Apellido del cliente"
        },
        "documentType": {
          "type": ["string", "null"],
          "description": "Tipo de documento del cliente"
        },
        "documentNumber": {
          "type": ["string", "null"],
          "description": "Número de documento del cliente"
        },
        "phone": {
          "type": ["string", "null"],
          "description": "Teléfono del cliente"
        }
      }
    },
    "shippings": {
      "type": "array",
      "description": "Envíos de la orden",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID del envío"
          },
          "type": {
            "type": "string",
            "enum": ["delivery", "store_pickup", "drive_through", "express_delivery"],
            "description": "Tipo de envío"
          },
          "status": {
            "type": "string",
            "enum": ["failed", "pending", "inProgress", "finished"],
            "description": "Estado del envío"
          },
          "deliveryEstimateDate": {
            "type": "string",
            "format": "date-time",
            "description": "Fecha estimada de entrega"
          }
        },
        "required": ["deliveryEstimateDate"]
      }
    },
    "payments": {
      "type": "array",
      "description": "Pagos de la orden",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID del pago"
          },
          "amount": {
            "type": "number",
            "description": "Monto del pago"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "finished", "canceled"],
            "description": "Estado del pago"
          },
          "paymentGroup": {
            "type": "string",
            "description": "Grupo de pago (tipo de pago)"
          }
        },
        "required": ["amount", "status"]
      }
    },
    "dateCreated": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de creación de la orden"
    },
    "dateModified": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de última modificación de la orden"
    }
  },
  "required": [
    "id",
    "status",
    "totalAmount",
    "items",
    "dateCreated",
    "dateModified"
  ],
  "additionalProperties": true
}
