{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "stores",
  "title": "Store",
  "description": "Schema de validación para tiendas del Commerce Service de Janis",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Identificador único de la tienda",
      "example": "631fb04c8fe08f51a8ee5949"
    },
    "name": {
      "type": "string",
      "description": "Nombre interno de la tienda en el sistema",
      "example": "Some Store"
    },
    "referenceId": {
      "type": "string",
      "description": "ID de referencia del cliente para la tienda",
      "example": "store-ref-id"
    },
    "locationId": {
      "type": "string",
      "description": "ID de la Location asociada a la tienda (referencia a Location entity)",
      "example": "5f611f7ea12359cca2ca0f07"
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive"],
      "description": "Estado de la tienda",
      "example": "active"
    },
    "location": {
      "type": ["object", "null"],
      "description": "Datos de la ubicación asociada (cuando se incluyen en la respuesta)",
      "properties": {
        "id": {
          "type": "string",
          "description": "ID de la ubicación"
        },
        "name": {
          "type": "string",
          "description": "Nombre de la ubicación"
        },
        "referenceId": {
          "type": "string",
          "description": "ID de referencia de la ubicación"
        },
        "latitude": {
          "type": ["number", "null"],
          "description": "Latitud de la ubicación",
          "example": -34.5864066
        },
        "longitude": {
          "type": ["number", "null"],
          "description": "Longitud de la ubicación",
          "example": -58.4321807
        },
        "countryIso3": {
          "type": ["string", "null"],
          "description": "País en formato ISO3",
          "example": "ARG"
        },
        "timezone": {
          "type": ["string", "null"],
          "description": "Timezone de la ubicación",
          "example": "America/Argentina"
        },
        "address": {
          "type": ["object", "null"],
          "description": "Dirección de la ubicación",
          "properties": {
            "street": { "type": ["string", "null"] },
            "number": { "type": ["string", "null"] },
            "city": { "type": ["string", "null"] },
            "state": { "type": ["string", "null"] },
            "country": { "type": ["string", "null"] },
            "zipCode": { "type": ["string", "null"] }
          }
        },
        "phoneNumber": {
          "type": ["string", "null"],
          "description": "Número de teléfono de la ubicación"
        }
      }
    },
    "dateCreated": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de creación de la tienda"
    },
    "dateModified": {
      "type": "string",
      "format": "date-time",
      "description": "Fecha de última modificación de la tienda"
    }
  },
  "required": [
    "id",
    "name",
    "referenceId",
    "locationId",
    "status",
    "dateCreated",
    "dateModified"
  ],
  "additionalProperties": true
}
