        "description": "The ID of the user who created the item",
        "type": "string",
        "readOnly": true,
        "example": "6a1fc1eeb5b68406e0487a10"
      },
      "userModified": {
        "description": "The ID of the user who last modified the item",
        "type": "string",
        "readOnly": true,
        "example": "7e1fc1eeb5b68406e048796"
      },
      "TemplatedClient": {
        "type": "object",
        "description": "A Templated Client",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "name": {
            "type": "string",
            "description": "The client name (this will be visible to users)",
            "example": "Apu's Kwik-E-Mart"
          },
          "code": {
            "type": "string",
            "description": "The client code (this will be used in API calls)",
            "example": "kwikemart"
          },
          "market": {
            "type": "string",
            "description": "The target market of the client",
            "example": "grocery",
            "enum": [
              "grocery",
              "retail",
              "homeAndDeco",
              "pharmacy",
              "fashion",
              "all"
            ]
          },
          "countryCode": {
            "type": "string",
            "description": "The ISO3 Code of the client country",
            "example": "ARG"
          },
          "locale": {
            "type": "string",
            "description": "The locale of the client",
            "example": "es"
          },
          "currencyCode": {
            "type": "string",
            "description": "The ISO3 Code of the client default currency",
            "example": "es"
          },
          "timezone": {
            "type": "string",
            "description": "The ISO Code of the client default timezone",
            "example": "es"
          },
          "createUsers": {
            "type": "boolean",
            "description": "Whether or not to create default users",
            "default": false,
            "example": false
          },
          "usersPassword": {
            "type": "string",
            "description": "The password to be set to the created users. This **MUST** be a strong password that passes the [default organization password requirements](https://app.janis.in/id/organization/new).\n\nRequired if `createUsers` is `true`\n",
            "writeOnly": true,
            "example": "Str0ngPa$$word!"
          },
          "useDemoDatasets": {
            "type": "boolean",
            "description": "Whether to apply a demo dataset to the client (locations, warehouses, carriers, catalog, etc)",
            "default": false,
            "example": false
          },
          "useStoredGoods": {
            "type": "boolean",
            "description": "Whether to use positions and stored goods or plain stock",
            "default": false,
            "example": false
          },
          "customization": {
            "type": "object",
            "description": "Client customization properties",
            "properties": {
              "clientImage": {
                "type": "string",
                "description": "An URL that points to the client logo",
                "example": "https://example.com/logo.png"
              },
              "mainColor": {
                "type": "string",
                "description": "The client's main color",
                "nullable": true,
                "example": "#1877c1"
              },
              "secondaryColor": {
                "type": "string",
                "description": "The client's secondary color",
                "nullable": true,
                "example": "#4e343a"
              }
            }
          },
          "process": {
            "description": "The status of the client processing",
            "type": "object",
            "readOnly": true,
            "properties": {
              "executionArn": {
                "description": "The ARN of the process state machine",
                "type": "string",
                "example": "arn:aws:states:us-east-1:000000000000:execution:StateMachineName:307b7798-965c-4659-86c0-8c0193cd3174"
              },
              "executionUrl": {
                "description": "The URL of the process state machine",
                "type": "string",
                "example": "https://us-east-1.console.aws.amazon.com/states/home#/executions/details/arn:aws:states:us-east-1:000000000000:execution:StateMachineName:307b7798-965c-4659-86c0-8c0193cd3174"
              },
              "startDate": {
                "description": "The date when the process started",
                "type": "string",
                "format": "date-time",
                "example": "2025-02-06T18:24:10Z"
              },
              "endDate": {
                "description": "The date when the process ended",
                "type": "string",
                "format": "date-time",
                "example": "2025-02-06T18:24:10Z"
              },
              "error": {
                "description": "The details of the error, in case the process fails",
                "type": "object",
                "additionalProperties": true,
                "example": {
                  "Error": "TypeError",
                  "Cause": "Some error cause"
                }
              }
            }
          },
          "resources": {
            "description": "The resources created for the client",
            "type": "object",
            "properties": {
              "clientId": {
                "description": "The client ID",
                "type": "string",
                "example": "631fb04c8fe08f51a8ee5949"
              }
            }
          },
          "status": {
            "description": "The status",
            "type": "string",
            "readOnly": true,
            "default": "pending",
            "enum": [
              "pending",
              "processing",
              "waitingClientCreation",
              "finished",
              "failed"
            ],
            "example": "pending"
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          }
        },
        "required": [
          "id",
          "name",
          "code",
          "market",
          "countryCode",
          "locale",
          "currencyCode",
          "timezone",
          "status",
          "userCreated",
          "dateCreated"
        ]
      },
      "TemplatedClientList": {
        "type": "array",
        "description": "A list of Templated Clients",
        "items": {
          "$ref": "#/components/schemas/TemplatedClient"
        }
      }
    }
  }
