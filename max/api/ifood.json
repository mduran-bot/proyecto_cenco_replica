          "id": {
            "$ref": "#/components/schemas/id"
          },
          "integrationOrderId": {
            "type": "string",
            "description": "The integration order id",
            "example": "V1StGXR8Z5jdHi6B"
          },
          "shortCode": {
            "$ref": "#/components/schemas/shortCode"
          },
          "accountId": {
            "type": "string",
            "description": "The id of the account associated with the order",
            "example": "672cdadd1849404bde3d0c70"
          },
          "deliveryId": {
            "type": "string",
            "description": "The id associated with order shipping",
            "example": "672cdadd1849404bde3d0c80"
          },
          "accountName": {
            "type": "string",
            "description": "The name of the account associated with the order",
            "example": "fizzmodarg"
          },
          "status": {
            "description": "The order status",
            "type": "string",
            "enum": [
              "accepted",
              "cancelled"
            ],
            "example": "accepted"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          }
        },
        "required": [
          "id",
          "integrationOrderId",
          "accountId",
          "accountName",
          "status"
        ]
      },
      "OrderList": {
        "type": "array",
        "description": "A list of orders",
        "items": {
          "$ref": "#/components/schemas/Order"
        }
      },
      "OrderStatusChange": {
        "type": "object",
        "description": "An Order Status Change",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "source": {
            "type": "string",
            "description": "The source of the status change",
            "enum": [
              "ifood",
              "oms"
            ],
            "example": "ifood"
          },
          "orderId": {
            "type": "string",
            "description": "The ifood id of the order",
            "example": "V1StGXR8Z5jdHi6B"
          },
          "shortCode": {
            "$ref": "#/components/schemas/shortCode"
          },
          "accountId": {
            "type": "string",
            "description": "The id of the account that originated the status change",
            "example": "672cdadd1849404bde3d0c70"
          },
          "accountName": {
            "type": "string",
            "description": "The name of the account that originated the status change",
            "example": "fizzmod"
          },
          "clientCode": {
            "type": "string",
            "description": "The client code of the order",
            "example": "defaultClient"
          },
          "loggingData": {
            "type": "array",
            "description": "A list of logging information of the status change process",
            "items": {
              "type": "string"
            },
            "example": [
              "Saved status change in DB"
            ]
          },
          "rawEvent": {
            "type": "object",
            "description": "The raw event of the order received from ifood"
          },
          "eventType": {
            "type": "string",
            "description": "The event type of the status order",
            "enum": [
              "created",
              "cancelled"
            ],
            "example": "created"
          },
          "status": {
            "description": "The order status change processing status",
            "type": "string",
            "default": "pending",
            "enum": [
              "pending",
              "processing",
              "processed",
              "skipped",
              "error"
            ],
            "example": "pending"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          }
        },
        "required": [
          "id",
          "source",
          "orderId",
          "accountId",
          "accountName",
          "clientCode",
          "eventType",
          "status"
        ]
      },
      "OrderStatusChangeList": {
        "type": "array",
        "description": "A list of Order Status Changes",
        "items": {
          "$ref": "#/components/schemas/OrderStatusChange"
