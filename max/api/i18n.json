              "$ref": "#/components/schemas/Release"
            }
          }
        }
      },
      "listReleasesSuccess": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Release"
              }
            }
          }
        }
      },
      "getTranslateSuccess": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Translate"
            }
          }
        }
      },
      "listTranslatesSuccess": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Translate"
              }
            }
          }
        }
      },
      "TranslateBatchResponse": {
        "description": "Batch responses",
        "content": {
          "application/json": {
            "schema": {
              "description": "Item Batch response",
              "type": "object",
              "properties": {
                "itemsCreated": {
                  "description": "Items which were created successfully. Each item is identified by its namespace and key.\n",
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TranslateBatchResponseCorrectItem"
                  }
                },
                "itemsUpdated": {
                  "description": "Items which were updated successfully. Each item is identified by its namespace and key.\n",
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TranslateBatchResponseCorrectItem"
                  }
                },
                "itemsNotModified": {
                  "description": "Items that did not need to be modified. Each item is identified by its namespace and key.\n",
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TranslateBatchResponseCorrectItem"
                  }
                },
                "itemsError": {
                  "description": "Items that were not valid. To be valid, a translate must have **only** valid languages. Each item is identified by its namespace and key.\n",
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "namespace": {
                        "$ref": "#/components/schemas/Translate/properties/namespace"
                      },
                      "key": {
                        "$ref": "#/components/schemas/Translate/properties/key"
                      },
                      "errorMessage": {
                        "description": "Failure message showing an error description",
                        "type": "string",
                        "example": "Language/s Pg and Es are invalid"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "headers": {
          "x-janis-total-created": {
            "$ref": "#/components/headers/x-janis-total-created"
          },
          "x-janis-total-updated": {
            "$ref": "#/components/headers/x-janis-total-updated"
          },
          "x-janis-total-not-modified": {
            "$ref": "#/components/headers/x-janis-total-not-modified"
          },
          "x-janis-total-error": {
            "$ref": "#/components/headers/x-janis-total-error"
          }
        }
      }
    },
    "schemas": {
      "id": {
        "description": "The unique identifier of the item",
        "type": "string",
        "readOnly": true,
        "example": "d555345345345as67a342a"
      },
      "status": {
        "description": "The item status",
        "type": "string",
        "default": "active",
        "enum": [
          "active",
          "inactive"
        ],
        "example": "active"
      },
      "dateCreated": {
        "description": "The date of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-12T19:00:00.000Z"
      },
      "dateModified": {
        "description": "The date of the last modification",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-20T19:00:00.000Z"
      },
      "userCreated": {
        "description": "The ID of the user who created the item",
        "type": "string",
        "readOnly": true,
        "example": "6a1fc1eeb5b68406e0487a10"
      },
      "userModified": {
        "description": "The ID of the user who last modified the item",
        "type": "string",
        "readOnly": true,
        "example": "7e1fc1eeb5b68406e048796"
      },
      "lastUsed": {
        "description": "The date of the last used of the translate",
        "type": "string",
        "format": "date-time",
        "example": "2019-07-20T19:00:00.000Z"
      },
      "Country": {
        "type": "object",
        "description": "A Country",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "name": {
            "type": "string",
            "description": "The name of the country",
            "example": "Argentina",
            "readOnly": true
          },
          "iso2": {
            "type": "string",
            "description": "The iso code in two letters",
            "example": "AR",
            "readOnly": true
          },
          "iso3": {
            "type": "string",
            "description": "The iso code in three letters",
            "example": "ARG",
            "readOnly": true
          },
          "currencies": {
            "type": "array",
            "description": "List of currencies. This refer to the `code` of the **Currency** Entity. See [Location](/v2/service/i18n#tag/Currency).",
            "readOnly": true,
            "items": {
              "type": "string",
              "description": "The currencies codes of the country",
              "example": "ARS"
            }
          },
          "defaultCurrency": {
            "type": "string",
            "description": "The common currency of the country",
            "example": "ARS",
            "readOnly": true
          },
          "languages": {
            "type": "array",
            "description": "The languages of the country",
            "readOnly": true,
            "items": {
              "type": "string",
              "description": "The language in iso639-1",
              "example": "es"
            }
          },
          "timezones": {
            "type": "array",
            "description": "A list of timezones of the country",
            "readOnly": true,
            "items": {
              "type": "string",
              "description": "The timezone UTC",
              "example": "UTC-03:00"
            }
          },
          "borders": {
            "type": "array",
            "description": "The iso2 codes of the border country of the country",
            "readOnly": true,
            "items": {
              "type": "string",
              "description": "A list of borders countries in iso3 code",
              "example": "URY"
            }
          }
        }
      },
      "CountryList": {
        "type": "array",
        "description": "A list of countries",
        "items": {
          "$ref": "#/components/schemas/Country"
        }
      },
      "Currency": {
        "type": "object",
        "description": "A currency",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "code": {
            "type": "string",
            "description": "The currency code",
            "example": "ARS",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "description": "The currency name",
            "example": "Argentine peso",
            "readOnly": true
          },
          "symbol": {
            "type": "string",
            "description": "The currency symbol",
            "example": "$",
            "readOnly": true
          },
          "countryNames": {
            "type": "array",
            "description": "A list of country names were the currency is used",
            "example": [
              "Argentina",
              "United States"
            ],
            "readOnly": true,
            "items": {
              "type": "string",
              "description": "The Country name"
            }
          }
        }
      },
      "CurrencyList": {
        "type": "array",
        "description": "A list of currencies",
        "items": {
          "$ref": "#/components/schemas/Currency"
        }
      },
      "Language": {
        "description": "Represents a language variant",
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "name": {
            "description": "The name",
            "type": "string",
            "example": "English (UK)"
          },
          "code": {
            "description": "The language 2-digit code",
            "type": "string",
            "example": "en"
          },
          "variant": {
            "description": "The language 2-digit variant",
            "type": "string",
            "example": "UK"
          },
          "fullCode": {
            "description": "The full code (concatenating code and variant with a hyphen, or just the code if variant is empty)",
            "type": "string",
            "readOnly": true,
            "example": "en-UK"
          },
          "fallback": {
            "description": "The fallback language full code (code or code-variant)",
            "type": "string",
            "example": "en"
          },
          "status": {
            "$ref": "#/components/schemas/status"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          },
          "userModified": {
            "$ref": "#/components/schemas/userModified"
          }
        },
        "required": [
          "id",
          "name",
          "code",
          "status"
        ]
      },
      "Release": {
        "description": "Represents a bundle of translates for an especific service and language",
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "namespace": {
            "description": "The namespace",
            "type": "string",
            "example": "common"
          },
          "language": {
            "description": "The full language",
            "type": "string",
            "example": "en-US"
          },
          "status": {
            "description": "The status name\n- `pending`: The translate is pending to be translated\n- `ready`: The translate is ready to be released\n- `needsReview`: The translate needs to be reviewed by a human\n",
            "type": "string",
            "enum": [
              "pending",
              "ready",
              "needsReview"
            ],
            "example": "pending"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          },
          "dateReleased": {
            "description": "The latest date it was released",
            "type": "string",
            "format": "date-time",
            "readOnly": true,
            "example": "2019-07-20T19:00:00.000Z"
          }
        },
        "required": [
          "id",
          "namespace",
          "language",
          "status"
        ]
      },
      "Timezone": {
        "type": "object",
        "description": "A Timezone",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "name": {
            "type": "string",
            "description": "The location name of the timezone",
            "example": "America/Argentina/Buenos_Aires",
            "readOnly": true
          },
          "country": {
            "type": "string",
            "description": "The country ID, This refer to the `id` of the **Country** Entity. See [Country](/v2/service/i18n#tag/Country).\n",
            "example": "d555345345345as67a342a",
            "readOnly": true
          },
          "countryIso2": {
            "type": "string",
            "description": "The iso code in two letters of the country time zone",
            "example": "AR",
            "readOnly": true
          },
          "countryName": {
            "type": "string",
            "description": "The name of the country time zone",
            "example": "Argentina",
            "readOnly": true
          },
          "gmtOffset": {
            "type": "string",
            "description": "The GMT offset of the timezone",
            "example": "-03:00",
            "readOnly": true
          },
          "gmtOffsetRaw": {
            "type": "number",
            "description": "The GMT offset of the timezone",
            "example": -10800,
            "readOnly": true
          }
        }
      },
      "TimezoneList": {
        "type": "array",
        "description": "A list of timezones",
        "items": {
          "$ref": "#/components/schemas/Timezone"
        }
      },
      "Translate": {
        "description": "Represents a key of translate without translation values",
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "namespace": {
            "description": "The namespace",
            "type": "string",
            "example": "common"
          },
          "key": {
            "description": "The key",
            "type": "string",
            "example": "message.success"
          },
          "status": {
            "description": "The item status",
            "type": "string",
            "default": "pending",
            "enum": [
              "pending",
              "ready"
            ],
            "example": "pending"
          },
          "translatedLanguages": {
            "description": "A list of translated languages, comma separated",
            "type": "string",
            "readOnly": true,
            "example": "es, en"
          },
          "values": {
            "description": "The translate values for each language. It's a mapping of language to value.",
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "example": {
              "es": "¡Éxito!",
              "en": "Success!"
            }
          },
          "autoTranslated": {
            "description": "Whether the translation was automatically generated",
            "type": "boolean",
            "readOnly": true,
            "default": false,
            "example": false
          },
          "lastUsed": {
            "$ref": "#/components/schemas/lastUsed"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          },
          "userModified": {
            "$ref": "#/components/schemas/userModified"
          }
        },
        "required": [
          "id",
          "namespace",
          "key"
        ]
      },
      "TranslateBatch": {
        "description": "A Translate Batch",
        "type": "array",
        "minItems": 1,
        "maxItems": 10000,
        "uniqueItems": true,
        "items": {
          "$ref": "#/components/schemas/TranslateBatchItem"
        }
      },
      "TranslateBatchItem": {
        "description": "A translate added",
        "type": "object",
        "properties": {
          "namespace": {
            "$ref": "#/components/schemas/Translate/properties/namespace"
          },
          "key": {
            "$ref": "#/components/schemas/Translate/properties/key"
          },
          "values": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Translate/properties/values"
              }
            ],
            "description": "The translate values for each language. It's a mapping of language to value. If the translation for any of the languages is not defined, it will be set as an empty string."
          },
          "lastUsed": {
            "$ref": "#/components/schemas/lastUsed"
          }
        },
        "required": [
          "namespace",
          "key"
        ]
      },
      "TranslateBatchResponseCorrectItem": {
        "description": "An item from the translate batch response.",
        "type": "object",
        "properties": {
          "namespace": {
            "$ref": "#/components/schemas/Translate/properties/namespace"
          },
          "key": {
            "$ref": "#/components/schemas/Translate/properties/key"
          },
          "values": {
            "$ref": "#/components/schemas/Translate/properties/values"
          },
          "id": {
            "$ref": "#/components/schemas/id"
          }
        }
      }
    }
  }
}