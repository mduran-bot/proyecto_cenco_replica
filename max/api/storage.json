  "paths": {
    "/credentials": {
      "get": {
        "x-janis-namespace": "credentials",
        "x-janis-method": "get",
        "x-janis-permissions": [],
        "x-janis-roles": [
          "deliveryLastMile"
        ],
        "operationId": "getCredentials",
        "tags": [
          "Credentials"
        ],
        "summary": "Get credentials to upload files",
        "security": [
          {
            "ApiKey": [],
            "ApiSecret": [],
            "JanisClient": []
          }
        ],
        "parameters": [
          {
            "name": "fileName",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The filename to sing (required if no fileNames param is received)"
          },
          {
            "name": "fileNames",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "The filenames to sign  (required if no fileName param is received)"
          },
          {
            "name": "serviceName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The serviceName of the Microservice"
          },
          {
            "name": "entity",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "items": {
                "type": "string",
                "example": "order"
              }
            },
            "description": "The file entity"
          },
          {
            "name": "expiration",
            "in": "query",
            "schema": {
              "type": "string",
              "example": 60
            },
            "description": "The credential expiration time in seconds"
          },
          {
            "name": "fileExpiration",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "oneDay",
                "tenDays",
                "month",
                "threeMonths",
                "sixMonths",
                "never"
              ]
            },
            "description": "The file expiration",
            "example": "oneDay"
          }
        ],
        "responses": {
          "200": {
            "description": "The credentials to upload each file",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Credentials"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/signed-files": {
      "get": {
        "x-janis-namespace": "getSignedFiles",
        "x-janis-method": "get",
        "x-janis-permissions": [],
        "operationId": "getSignedFiles",
        "tags": [
          "Signed Files"
        ],
        "summary": "Get the files signed",
        "parameters": [
          {
            "name": "paths",
            "in": "query",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "The paths to sign"
          }
        ],
        "responses": {
          "200": {
            "description": "The signed files",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignedFiles"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
