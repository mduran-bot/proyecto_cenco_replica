            "example": {
              "image.png": {
                "url": "https://s3.amazonaws.com/bucketName",
                "fields": {
                  "key": "cdn/files/cientCode/3CM6sniEdXTBeDWMtqpUcvWocWoxrmMr.png",
                  "bucket": "janis-storage-service-local",
                  "X-Amz-Algorithm": "AWS4-ABC-SHA256",
