            "example": {
              "cdn/files/clientCode/U2ZPvzsjjTeUy5v56VZjkTUyacfKyE3P.png": "https://cdn.storage.janis.in/files/clientCode/image.png?Expires=1673308800&Key-Pair-Id=K33I33M2DJ895M&Signature=Q-EUWM2F3fULQxEDuCi8BZ2YU3lwuqjf3pIJVm"
            }
          }
        },
        "required": [
          "fileNames"
        ]
      },
      "Files": {
        "type": "object",
        "description": "The Files with the information",
        "additionalProperties": {
          "type": "string"
        },
        "example": {
          "cdn/files/clientCode/U2ZPvzsjjTeUy5v56VZjkTUyacfKyE3P.txt": "file content"
        }
      },
      "FilesInfo": {
        "type": "object",
        "description": "The Files with the information",
        "properties": {
