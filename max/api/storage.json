                  "X-Amz-Date": "20230110T202205Z",
                  "Policy": "eyJleHBpcmF0aW9uIjoiMjAyMy0wMS0xMFQyMDoyMzowNVoiLCJjb25kaXRpb==",
                  "X-Amz-Signature": "fe2e87697802a40481393c05839a904"
                }
              }
            }
          }
        },
        "required": [
          "fileNames"
        ]
      },
      "SignedFiles": {
        "type": "object",
        "description": "The Files signed",
        "properties": {
