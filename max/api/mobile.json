                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Not authorized request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "InternalError": {
        "description": "A server error has ocurred."
      },
      "getDownload": {
        "description": "The file was successfully found. User should be redirected to download the file."
      }
    },
    "schemas": {
      "id": {
        "description": "The unique identifier of the item",
        "type": "string",
        "readOnly": true,
        "example": "631fb04c8fe08f51a8ee5949"
      },
      "status": {
        "description": "The item status",
        "type": "string",
        "default": "active",
        "enum": [
          "active",
          "inactive"
        ],
        "example": "active"
      },
      "dateCreated": {
        "description": "The date of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-12T19:00:00.000Z"
      },
      "dateModified": {
        "description": "The date of the last modification",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-20T19:00:00.000Z"
      },
      "dateCreatedDay": {
        "description": "The day of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-08-07T16:00:00.000Z"
      },
      "dateModifiedDay": {
        "description": "The day of last modification",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-08-07T16:00:00.000Z"
      },
      "userCreated": {
        "description": "The ID of the user who created the item",
        "type": "string",
        "readOnly": true,
        "example": "6a1fc1eeb5b68406e0487a10"
      },
      "userModified": {
        "description": "The ID of the user who last modified the item",
        "type": "string",
        "readOnly": true,
        "example": "7e1fc1eeb5b68406e048796"
      },
      "App": {
        "type": "object",
        "description": "A App",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "name": {
            "type": "string",
            "description": "The name of the app",
            "example": "Janis Picking App",
            "readOnly": true,
            "enum": [
              "Janis Picking App",
              "Janis Delivery App",
              "Janis WMS App"
            ]
          },
          "packageName": {
            "type": "string",
            "description": "The Package name of the app",
            "example": "in.janis.picking",
            "enum": [
              "in.janis.picking",
              "in.janis.picking.qa",
              "in.janis.picking.beta",
              "in.janis.delivery",
              "in.janis.delivery.qa",
              "in.janis.delivery.beta",
              "in.janis.wms",
              "in.janis.wms.qa",
              "in.janis.wms.beta"
            ]
          },
          "version": {
            "type": "string",
            "description": "The version of the app",
            "example": "1.2.0.qa"
          },
          "build": {
            "type": "number",
            "description": "The build number of the app",
            "example": 132
          },
          "os": {
            "type": "string",
            "description": "The operative system of the app",
            "example": "android",
            "enum": [
              "android",
              "ios"
            ]
          },
          "isMinorVersion": {
            "type": "boolean",
            "description": "This property determinate if is a minor version of the app",
            "example": true
          },
          "status": {
            "$ref": "#/components/schemas/status"
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "userModified": {
            "$ref": "#/components/schemas/userModified"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          }
        },
        "required": [
          "id",
          "name",
          "packageName",
          "version",
          "build",
          "os",
          "status",
          "userCreated",
          "dateCreated",
          "userModified",
          "dateModified"
        ]
      },
      "AppList": {
        "type": "array",
        "description": "A list of Apps",
        "items": {
          "$ref": "#/components/schemas/App"
        }
      },
      "FileList": {
        "type": "array",
        "description": "A list of orders",
        "items": {
          "$ref": "#/components/schemas/File"
        }
      },
      "File": {
        "type": "object",
        "description": "A file uploaded by a user",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "type": {
            "type": "string",
            "description": "The file type",
            "readOnly": true,
            "enum": [
              "video",
              "image",
              "doc",
              "sheet",
              "other"
            ],
            "example": "image"
          },
          "name": {
            "type": "string",
            "description": "The file name",
            "example": "image.png"
          },
          "size": {
            "type": "integer",
            "description": "The file size in bytes",
            "readOnly": true,
            "example": 2048
          },
          "expireAt": {
            "type": "string",
            "format": "date-time",
            "description": "The expiration date of the file. Upon reaching that date, the file will be removed from the DB.",
            "readOnly": true,
            "example": "2023-03-13T19:00:00.816Z"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          }
        },
        "required": [
          "name"
        ]
      },
      "FileSignedGetUrl": {
        "type": "object",
        "description": "The URL of the file with a temporal signature to be downloaded",
        "properties": {
          "url": {
            "type": "string",
            "description": "The URL of the file with a temporal signature to be downloaded",
            "readOnly": true,
            "example": "https://cdn.storage.janis.in/some-bucket-name/image.png"
          }
        }
      },
      "SingleCredential": {
        "type": "object",
        "title": "SingleCredential (if send parameter fileName)",
        "description": "The name of the file.",
        "properties": {
          "url": {
            "description": "The Bucket url",
            "type": "string",
            "example": "https://s3.amazonaws.com/janis-storage-service-beta"
          },
          "fields": {
            "description": "The fields to request Amazon",
            "type": "object",
            "properties": {
              "Content-Type": {
                "description": "The content type to request Amazon",
                "type": "string",
                "example": "image/png"
              },
              "key": {
                "description": "The request's key to put the data.\nThe key is generated by the server and is unique for each file.\n",
                "type": "string",
                "example": "entities: cdn/files/clientCode/2023/01/10/c97b76ab-488e-4d74-9198-9a805562f3d7.png\n"
              },
              "bucket": {
                "description": "The bucket's name.\nThis must not contain uppercase characters.\n",
                "type": "string",
                "example": "janis-oms-service-beta"
              },
              "X-Amz-Algorithm": {
                "description": "The Amz algorithm's name",
                "type": "string",
                "example": "AWS4-HMAC-SHA256"
              },
              "X-Amz-Credential": {
                "description": "The Amz's Credential",
                "type": "string",
                "example": "ASIASU7VKOIIHH6UPMSE/20201216/us-east-1/s3/aws4_request"
              },
              "X-Amz-Date": {
                "description": "The Amz's date",
                "type": "string",
                "example": "20201216T152315Z"
              },
              "X-Amz-Security-Token": {
                "description": "The Amz's security Token",
                "type": "string",
                "example": ""
              },
              "Policy": {
                "description": "The request's policy",
                "type": "string",
                "example": ""
              },
              "X-Amz-Signature": {
                "description": "The Amz's signature",
                "type": "string",
                "example": "fb0855d2b4fa5271b7e1ffa9712c9a37dd9ab37475ff8cce25c4650beafcc4ac"
              }
            }
          }
        }
      },
      "MultiplesCredentials": {
        "description": "The data required to upload data to Amazon Bucket.",
        "type": "object",
        "title": "MultiplesCredentials (if send the parameter fileNames)",
        "properties": {
          "image.png": {
            "$ref": "#/components/schemas/SingleCredential"
          }
        }
      },
      "listenerEvent": {
        "description": "A JANIS Event object",
        "type": "object",
        "properties": {
          "service": {
            "description": "The source service name",
            "type": "string",
            "example": "id"
          },
          "entity": {
            "description": "The event related entity",
            "type": "string",
            "example": "profile"
          },
          "event": {
            "description": "The event name",
            "type": "string",
            "example": "created"
          },
          "client": {
            "description": "The source event client",
            "type": "string",
            "example": "fizzmod"
          },
          "id": {
            "description": "The event related entity ID",
            "type": "string",
            "example": "5d699c1ae8ebb95eaa24aca9"
          }
        },
        "required": [
          "service",
          "entity",
          "event"
        ]
      }
    }
  }
}