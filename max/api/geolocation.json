      "AddressGeocoded_API": {
        "description": "The address was geocoded successfully",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "latitude": {
                  "description": "The location latitude",
                  "type": "number",
                  "minimum": -90,
                  "maximum": 90
                },
                "longitude": {
                  "description": "The location longitude",
                  "type": "number",
