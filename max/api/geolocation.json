  "paths": {
    "/address-validation": {
      "post": {
        "x-janis-namespace": "address-validation",
        "x-janis-method": "post",
        "x-janis-permissions": [],
        "operationId": "postAddressValidation",
        "tags": [
          "Address Validation"
        ],
        "summary": "Complete information of an address",
        "description": "It obtains all data from an incomplete address\n",
        "security": [
          {
            "ApiKey": [],
            "ApiSecret": [],
            "JanisClient": []
          }
        ],
        "requestBody": {
          "description": "The address to complete",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "address": {
                    "description": "The address to complete, if possible add city and country to achieve unambiguous results",
                    "type": "string",
                    "example": "Dorrego 965 Piso 1, Rosario"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompleteAddress"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/geocode": {
      "post": {
        "x-janis-namespace": "geocode",
        "x-janis-method": "create",
        "x-janis-permissions": [],
        "deprecated": true,
        "operationId": "createGeocode",
        "tags": [
          "Geocode"
        ],
        "summary": "Geocode an address",
        "description": "**DEPRECATED** This API is deprecated and will be removed in the future.\n\nNo production flows should rely on this API.\n",
        "security": [
          {
            "ApiKey": [],
            "ApiSecret": [],
            "JanisClient": []
          }
        ],
        "requestBody": {
          "description": "The adrress to geocode",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddressToGeocode_API"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/AddressGeocoded_API"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/ServiceLimitReached"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/setting/{entity}": {
      "get": {
        "x-janis-namespace": "setting",
        "x-janis-method": "get",
        "x-janis-permissions": [
          "geolocation:setting:read"
        ],
        "operationId": "getSetting",
        "tags": [
          "Settings"
        ],
        "summary": "Get the setting of an entity",
        "security": [
          {
            "ApiKey": [],
            "ApiSecret": [],
            "JanisClient": []
          }
        ],
        "parameters": [
          {
            "name": "entity",
            "in": "path",
            "schema": {
              "type": "string",
              "example": "googleMaps"
            },
            "required": true,
            "description": "The name of the entity that owns the settings to be retrieved"
          }
        ],
        "responses": {
          "200": {
            "description": "The settings were retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ProvidersSettings"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      },
      "put": {
        "x-janis-namespace": "setting",
        "x-janis-method": "update",
        "x-janis-permissions": [
          "geolocation:setting:write"
        ],
        "operationId": "updateSetting",
        "tags": [
          "Settings"
        ],
        "summary": "Update the setting of an entity",
        "security": [
          {
            "ApiKey": [],
            "ApiSecret": [],
            "JanisClient": []
          }
        ],
        "parameters": [
          {
            "name": "entity",
            "in": "path",
            "schema": {
              "type": "string",
              "example": "providers"
            },
            "required": true,
            "description": "The name of the entity that owns the settings to be updated"
          }
        ],
        "requestBody": {
          "description": "The settings configurations",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/ProvidersSettings"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The settings were updated"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
