          }
        }
      },
      "PublicOrderItem": {
        "type": "object",
        "description": "An order item",
        "properties": {
          "id": {
            "type": "string",
            "description": "The ID of the item. It must be alphanumeric and unique among all the items or the order.",
            "example": "590BFDDC88AC4006B7A6A841192A8D91"
          },
          "name": {
            "type": "string",
            "description": "The order item name",
            "example": "Coca Cola 1.5L"
          },
          "refId": {
            "type": "string",
            "description": "The order item Ref ID.",
            "example": "54987145487"
          },
          "ean": {
            "type": "string",
            "description": "The order item purchased **EAN**.",
            "example": "7002454588878"
          },
          "purchasedPrice": {
            "type": "number",
            "description": "The order item purchased price",
            "example": 78.5
          },
          "purchasedListPrice": {
            "type": "number",
            "description": "The order item purchased list price",
            "example": 78.5
          },
          "purchasedPricePerMeasurementUnit": {
            "type": "number",
            "description": "The order item purchased price per measurement unit",
            "example": 78.5
          },
          "purchasedQuantity": {
            "type": "number",
            "description": "The order item purchased quantity",
            "example": 2
          },
          "sellingMeasurementUnit": {
            "type": "string",
            "description": "The order item **Measurement Unit**",
            "example": "un"
          },
          "sellingUnitMultiplier": {
            "type": "number",
            "description": "The order item **Unit Multiplier**",
            "example": 1
          },
          "imageUrl": {
            "type": "string",
            "description": "The order item image URL",
            "example": "https://s3-eu-west-1.amazonaws.com/images.linnlive.com/b4cd1a0cb6423a903a87b5635027e08b/f40c553b-33a5-460f-9962-a4e660c7ef02.jpg"
          },
          "shippingPrice": {
            "type": "number",
            "description": "The order item shipping price",
            "example": 1.5
          },
          "brandName": {
            "type": "string",
            "description": "The order item's **Brand** name",
            "example": "La Campagnola"
          },
          "categories": {
            "type": "array",
            "description": "The **Categories** that applied to the item",
            "items": {
              "type": "object",
              "description": "An order **Category**",
              "properties": {
                "commerceId": {
                  "type": "string",
                  "description": "The **Category** commerce id",
                  "example": "1"
                },
                "name": {
                  "type": "string",
                  "description": "The **Category** commerce name",
                  "example": "Food"
                }
              }
            }
          },
          "pickingResult": {
            "type": "array",
            "description": "A list of picked items. This can be sent when creating an order if the picking process happened before the creation of the order in Janis\n",
            "items": {
              "$ref": "#/components/schemas/PublicOrderItemPickingResultItem"
            }
          }
        }
      },
      "PublicOrderItemPickingResultItem": {
        "type": "object",
        "description": "Picked item",
        "properties": {
          "id": {
            "type": "string",
            "description": "A unique identifier for the current picking result item.",
            "example": "590BFDDC88AC4006B7A6A841192A8D91-0"
          },
          "name": {
            "type": "string",
            "description": "The item name",
            "example": "Coca Cola 1.5L"
          },
          "refId": {
            "type": "string",
            "description": "The picked product reference ID.",
            "example": "54987145487"
          },
          "ean": {
            "type": "string",
            "description": "The order item picked **EAN**",
            "example": "7002454588878"
          },
          "isSubstitute": {
            "type": "boolean",
            "description": "Indicates if the picked item is a substitute for the original order item",
            "example": true
          },
          "isCandidate": {
            "type": "boolean",
            "description": "Indicates if an item is a candidate for the customer's final choice",
            "example": true
          },
          "eanCount": {
            "type": "number",
            "description": "The amount of items with the same EAN that were picked",
            "example": 2
          },
          "quantityPerEan": {
            "type": "number",
            "description": "The quantity of the current picked item for each picked EAN (the measurement unit of this field is the one in `measurementUnit`)",
            "example": 1
          },
          "realQuantity": {
            "type": "number",
            "description": "The total amount quantity of the current picked item (the measurement unit of this field is the one in `measurementUnit`)",
            "example": 1
          },
          "price": {
            "type": "number",
            "description": "The price of each quantity of `measurementUnit`s of the picked item.",
            "example": 78.5
          },
          "sellingMeasurementUnit\"": {
            "type": "string",
            "description": "The item **Measurement Unit** that is used for selling the product.",
            "example": "un"
          },
          "sellingUnitMultiplier": {
            "type": "number",
            "description": "The item **Unit Multiplier** that is used for selling the product.",
            "example": 1
          },
          "measurementUnit": {
            "type": "string",
            "description": "The item **Measurement Unit** of the product.",
            "example": "un"
          },
          "unitMultiplier": {
            "type": "number",
            "description": "The item **Unit Multiplier** of the product.",
            "example": 1
          },
          "imageUrl": {
            "type": "string",
            "description": "The item image URL.",
            "example": "https://s3-eu-west-1.amazonaws.com/images.linnlive.com/b4cd1a0cb6423a903a87b5635027e08b/f40c553b-33a5-460f-9962-a4e660c7ef02.jpg"
          },
          "time": {
            "type": "number",
            "description": "The time in seconds spent in the picking process of this item",
            "example": 10
          }
        }
      },
      "PublicOrderCustomer": {
        "type": "object",
        "description": "A customer of the order",
        "properties": {
          "email": {
            "type": "string",
            "description": "The customer's email",
            "example": "john.doe@example.com"
          },
          "fullname": {
            "type": "string",
            "description": "The customer's fullname",
            "example": "John Doe"
          }
        }
      },
      "ItemsToReplaceList": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/ItemToReplace"
        }
      },
      "ItemToReplace": {
        "type": "object",
        "description": "The original item to be replaced and the choices candidates",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/PublicOrderItem/properties/id"
          },
          "candidates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemChoose"
            }
          }
        },
        "required": [
          "id",
          "candidates"
        ]
      },
      "ItemChoose": {
        "type": "object",
        "description": "The candidate item choose",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/PublicOrderItemPickingResultItem/properties/id"
          },
          "quantity": {
            "type": "number",
            "description": "The total amount quantity of the current picked item",
            "example": 1
          }
        },
        "required": [
          "id"
        ]
      },
      "OmsPublicOrderSettings": {
        "type": "object",
        "description": "Order settings",
        "title": "Order",
        "properties": {
          "customerSessionDuration": {
            "type": "number",
            "description": "Duration in minutes of the customer permissions to see and make changes to a public order",
            "example": 15,
            "default": 60
          },
          "orderItemsCandidatesExpirationBehavior": {
            "type": "string",
            "description": "Determines the action to do once the public order expires and there are not confirmed candidates",
            "example": "nothing",
            "enum": [
              "nothing",
              "markItemsAsMissing"
            ]
          },
          "maximumReschedules": {
            "type": "number",
            "description": "Determines the maximum reschedules for an order",
            "example": 2,
            "default": 1
          },
          "maximumReschedulingTimeInDays": {
            "type": "number",
            "description": "Determines the maximum time in days for rescheduling an order",
            "example": 3,
            "default": 7
          },
          "deliveryMethodsEnabledToReschedule": {
            "type": "array",
            "description": "Determines the delivery methods enabled to reschedule an order",
            "items": {
              "type": "string",
              "enum": [
                "delivery",
                "store_pickup",
                "drive_through",
                "express_delivery"
              ]
            }
          },
          "carriersEnabledToReschedule": {
            "type": "array",
            "description": "Determines carriers enabled to reschedule an order",
            "items": {
              "type": "string",
              "example": "1555345345345as67a342a"
            }
          }
        }
      },
      "listenerEvent": {
        "description": "A JANIS Event object",
        "type": "object",
        "properties": {
          "service": {
            "description": "The source service name",
            "type": "string",
            "example": "id"
          },
          "entity": {
            "description": "The event related entity",
            "type": "string",
            "example": "profile"
          },
          "event": {
            "description": "The event name",
            "type": "string",
            "example": "created"
          },
          "client": {
            "description": "The source event client",
            "type": "string",
            "example": "fizzmod"
          },
          "id": {
            "description": "The event related entity ID",
            "type": "string",
            "example": "5d699c1ae8ebb95eaa24aca9"
          }
        },
        "required": [
          "service",
          "entity",
          "event"
        ]
      },
      "FunctionError": {
        "type": "object",
        "description": "The error message",
        "properties": {
          "message": {
            "description": "The error message",
            "type": "string",
            "readOnly": true,
            "example": "An error occurred"
          }
        }
      }
    }
  }
}