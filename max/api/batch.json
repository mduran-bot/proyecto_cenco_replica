        "description": "User has sent too many requests in the established time range",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string",
                  "example": "Too many requests, try again later."
                }
              }
            }
          }
        }
      },
      "InternalError": {
        "description": "A server error has ocurred."
      }
    },
    "schemas": {
      "id": {
        "description": "The unique identifier of the item",
        "type": "string",
        "readOnly": true,
        "example": "d555345345345as67a342a"
      },
      "status": {
        "description": "The item status",
        "type": "string",
        "default": "active",
        "enum": [
          "active",
          "inactive"
        ],
        "example": "active"
      },
      "dateCreated": {
        "description": "The date of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-12T19:00:00.000Z"
      },
      "dateModified": {
        "description": "The date of the last modification",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-20T19:00:00.000Z"
      },
      "dateCreatedDay": {
        "description": "The day of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-08-07T16:00:00.000Z"
      },
      "dateCreatedFrom": {
        "description": "The date of creation as starting point",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-08-07T16:00:00.000Z"
      },
      "dateCreatedTo": {
        "description": "The date of creation as ending point",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-09-07T16:00:00.000Z"
      },
      "dateModifiedDay": {
        "description": "The day of last modification",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-08-07T16:00:00.000Z"
      },
      "userCreated": {
        "description": "The ID of the user who created the item",
        "type": "string",
        "readOnly": true,
        "example": "6a1fc1eeb5b68406e0487a10"
      },
      "userModified": {
        "description": "The ID of the user who last modified the item",
        "type": "string",
        "readOnly": true,
        "example": "7e1fc1eeb5b68406e048796"
      },
      "Import": {
        "description": "An import file",
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "service": {
            "description": "The service name to import",
            "type": "string",
            "example": "catalog"
          },
          "entity": {
            "description": "The entity name to import",
            "type": "string",
            "example": "product"
          },
          "name": {
            "description": "The name of the file to import",
            "type": "string",
            "example": "products.csv"
          },
          "path": {
            "description": "The path on the bucket of the file to import",
            "type": "string",
            "example": "client-code/imports/5dea9fc691240d00084083f8/file.csv"
          },
          "type": {
            "description": "The import type",
            "type": "string",
            "example": "sheet"
          },
          "totals": {
            "description": "The import process totals",
            "type": "object",
            "properties": {
              "total": {
                "description": "The total amount of received items to import",
                "type": "number",
                "example": 10000
              },
              "created": {
                "description": "The total amount of items created",
                "type": "number",
                "example": 2400
              },
              "updated": {
                "description": "The total amount of items updated",
                "type": "number",
                "example": 3500
              },
              "notModified": {
                "description": "The total amount of items not modified",
                "type": "number",
                "example": 1200
              },
              "error": {
                "description": "The total amount of items failed to import",
                "type": "number",
                "example": 500
              }
            },
            "readOnly": true
          },
          "dateStart": {
            "description": "The ISO date when the import should start",
            "type": "string",
            "format": "date-time",
            "example": "2019-07-12T19:00:00.000Z",
            "nullable": true
          },
          "dateEnd": {
            "description": "The ISO date when the import finished",
            "type": "string",
            "format": "date-time",
            "example": "2019-07-12T19:30:00.000Z",
            "readOnly": true
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          },
          "userModified": {
            "$ref": "#/components/schemas/userModified"
          },
          "status": {
            "description": "The status of the import",
            "type": "string",
            "enum": [
              "pending",
              "processing",
              "processed",
              "error"
            ],
            "example": "processed",
            "readOnly": true
          }
        }
      },
      "ImportCreate": {
        "description": "Import Create Request Body",
        "type": "object",
        "properties": {
          "service": {
            "$ref": "#/components/schemas/Import/properties/service"
          },
          "entity": {
            "$ref": "#/components/schemas/Import/properties/entity"
          },
          "fileName": {
            "$ref": "#/components/schemas/Import/properties/name"
          },
          "fileSource": {
            "$ref": "#/components/schemas/Import/properties/path"
          },
          "dateStart": {
            "$ref": "#/components/schemas/Import/properties/dateStart"
          }
        },
        "required": [
          "service",
          "entity",
          "fileName",
          "fileSource"
        ]
      },
      "ImportFile": {
        "description": "Import file name and S3 signed URL",
        "type": "object",
        "properties": {
          "fileName": {
            "description": "Import file name",
            "type": "string",
            "example": "price-1.csv"
          },
          "url": {
            "description": "Import file S3 signed URL",
            "type": "string",
            "example": "https://s3.amazonaws.com/imports/some-client/468745646876"
          }
        }
      },
      "ImportList": {
        "type": "array",
        "description": "A list of imports",
        "items": {
          "$ref": "#/components/schemas/Import"
        }
      },
      "ImportContent": {
        "type": "object",
        "properties": {
          "url": {
            "description": "The url to the bucket",
            "type": "string",
            "example": "https://s3.amazonaws.com/janis-batch-service-beta"
          },
          "fields": {
            "description": "The response fields",
            "type": "object",
            "properties": {
              "Content-Type": {
                "description": "Type of the file sended",
                "type": "string",
                "example": "file.csv"
              },
              "key": {
                "description": "Path to the file on the bucket",
                "type": "string",
                "example": "fizzmodarg/imports/file.csv/6f5bd593-3fb6-47f4-acf4-9a8654429982.csv"
              },
              "bucket": {
                "description": "The bucket name",
                "type": "string",
                "example": "janis-batch-service-beta"
              },
              "X-Amz-Algorithm": {
                "description": "Amazon algorithm",
                "type": "string",
                "example": "AWS4-HMAC-SHA256"
              },
              "X-Amz-Credential": {
                "description": "Amazon credentials",
                "type": "string",
                "example": "ASIAUIRT5BX7SEROP3HR/20201119/us-east-1/s3/aws4_request"
              },
              "X-Amz-Date": {
                "description": "Amazon date",
                "type": "string",
                "example": "20201119T205516Z"
              },
              "X-Amz-Security-Token": {
                "description": "Amazon security token",
                "type": "string",
                "example": "IQoJb3JpZ2luX2VjEO3//////////wEaCXVzLWVhc3QtMSJGMEQCIDB/o5QIbb618boNCouEm0z2xvJBy/kfTbQZWOCYbgasAiA6F2NHEna/oOFV3om6b3IvgmCej0Psfmfl4NOsVmMKZSreAQhmEAAaDDI5MzI0MDM3NjgzMSIMpiHvxj"
              },
              "Policy": {
                "description": "Policy token",
                "type": "string",
                "example": "eyJleHBpcmF0aW9uIjoiMjAyMC0xMS0xOVQyMDo1NjoxNloiLCJjb25kaXRpb25zIjpbWyJjb250ZW50LWxlbmd0aC1yYW5nZSIsMSwxMDQ4NTc2MF0seyJDb250ZW50LVR5cGUiOiJ0ZXh0L2NzcyJ9LHsia2V5IjoiZml"
              },
              "X-Amz-Signature": {
                "description": "Amazon signature",
                "type": "string",
                "example": "5203c9cf9bfd1df42d9e54b23b1a4c6b8cad69da0643ee0eb127e4853c9baf64"
              }
            }
          }
        }
      },
      "Export": {
        "description": "An export entry",
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "service": {
            "description": "The service where to export",
            "type": "string",
            "example": "Pricing"
          },
          "entity": {
            "description": "The entity to export",
            "type": "string",
            "example": "price"
          },
          "total": {
            "description": "The total amount of exported items",
            "type": "number",
            "example": 2500,
            "readOnly": true
          },
          "format": {
            "description": "The export file format",
            "type": "string",
            "enum": [
              "json",
              "csv",
              "xlsx"
            ],
            "example": "json"
          },
          "filters": {
            "description": "The filters to apply to data to export",
            "type": "object",
            "example": {
              "status": "active",
              "name": "someName"
            }
          },
          "sortBy": {
            "description": "The export sort by field",
            "type": "string",
            "example": "status"
          },
          "sortDirection": {
            "description": "The export sort direction",
            "type": "string",
            "enum": [
              "asc",
              "desc"
            ],
            "example": "asc"
          },
          "timezone": {
            "description": "The export timezone, this will be the timezone used to export date fields that uses formatting.\nThis refers to the field `name` of the **timezone** entity of [i18n Service](/v2/service/i18n#tag/Timezone)\n\nIf not present, it will use UTC by default.\n",
            "type": "string",
            "example": "America/Argentina/Buenos_Aires"
          },
          "dateStart": {
            "description": "The export process date start",
            "type": "string",
            "format": "date-time",
            "readOnly": true,
            "example": "2021-12-13T14:35:00.000Z"
          },
          "dateEnd": {
            "description": "The export process date end",
            "type": "string",
            "format": "date-time",
            "readOnly": true,
            "example": "2021-12-13T14:40:00.000Z"
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          },
          "userModified": {
            "$ref": "#/components/schemas/userModified"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          },
          "status": {
            "description": "The export process status",
            "type": "string",
            "enum": [
              "pending",
              "processing",
              "processed",
              "sent",
              "sendError",
              "error"
            ],
            "example": "processed",
            "readOnly": true
          }
        }
      },
      "ExportCreate": {
        "description": "An export to create",
        "type": "object",
        "properties": {
          "service": {
            "$ref": "#/components/schemas/Export/properties/service"
          },
          "entity": {
            "$ref": "#/components/schemas/Export/properties/entity"
          },
          "format": {
            "$ref": "#/components/schemas/Export/properties/format"
          },
          "filters": {
            "$ref": "#/components/schemas/Export/properties/filters"
          },
          "sortBy": {
            "$ref": "#/components/schemas/Export/properties/sortBy"
          },
          "sortDirection": {
            "$ref": "#/components/schemas/Export/properties/sortDirection"
          },
          "timezone": {
            "$ref": "#/components/schemas/Export/properties/timezone"
          }
        },
        "required": [
          "service",
          "entity"
        ]
      },
      "ExportedFile": {
        "description": "Exported file name and S3 signed URL",
        "type": "object",
        "properties": {
          "fileName": {
            "description": "Exported file name",
            "type": "string",
            "example": "price-1.xlsx"
          },
          "url": {
            "description": "Exported file S3 signed URL",
            "type": "string",
            "example": "https://s3.amazonaws.com/exports/some-client/468745646876"
          }
        }
      },
      "ExportedFiles": {
        "description": "Exported file names and S3 signed URLs",
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/ExportedFile"
        }
      },
      "ExportedViewLink": {
        "description": "The exported entity browse view link, including filters and sorting",
        "type": "string",
        "readOnly": true,
        "example": "https://app.janis.in/pricing/price/browse?sortBy=sku"
      }
    }
  }
