              "$ref": "#/components/schemas/Flow/properties/dateCreated"
            },
            "dateModified": {
              "$ref": "#/components/schemas/Flow/properties/dateModified"
            },
            "userCreated": {
              "$ref": "#/components/schemas/Flow/properties/userCreated"
            },
            "userModified": {
              "$ref": "#/components/schemas/Flow/properties/userModified"
            }
          }
        }
      },
      "RequestId": {
        "name": "id",
        "in": "path",
        "schema": {
          "type": "string",
          "example": "d555345345345as67a342a"
        },
        "required": true,
        "description": "The request ID"
      },
      "RequestSortBy": {
        "name": "sortBy",
        "in": "query",
        "description": "The field to sort by",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "flowId",
            "dateCreated",
            "dateModified"
          ]
        }
      },
      "RequestFilters": {
        "name": "filters",
        "in": "query",
        "description": "The filters to apply to the list",
        "required": false,
        "style": "deepObject",
        "explode": true,
        "schema": {
          "type": "object",
          "properties": {
            "flowId": {
              "$ref": "#/components/schemas/Request/properties/flowId"
            },
            "orderId": {
              "$ref": "#/components/schemas/Request/properties/orderId"
            },
            "dateCreated": {
              "$ref": "#/components/schemas/Request/properties/dateCreated"
            },
            "dateModified": {
              "$ref": "#/components/schemas/Request/properties/dateModified"
            },
            "userCreated": {
              "$ref": "#/components/schemas/Request/properties/userCreated"
            },
            "userModified": {
              "$ref": "#/components/schemas/Request/properties/userModified"
            }
          }
        }
      },
      "RequestOrderItemFilters": {
        "name": "filters",
        "in": "query",
        "description": "The filters to apply",
        "required": true,
        "style": "deepObject",
        "explode": true,
        "schema": {
          "type": "object",
          "properties": {
            "order": {
              "description": "The order ID",
              "type": "string",
              "example": "6ddd38fbfd60ad001118dbec"
            }
          },
          "required": [
            "order"
          ]
        }
      }
    },
    "headers": {
      "x-janis-total": {
        "description": "The total amount of records in the list",
        "schema": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "responses": {
      "SuccessCreateResponse": {
        "description": "The item was created",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "$ref": "#/components/schemas/id"
                }
              }
            }
          }
        }
      },
      "SuccessUpdateResponse": {
        "description": "The item was updated",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "$ref": "#/components/schemas/id"
                }
              }
            }
          }
        }
      },
      "GenericSuccess": {
        "description": "Operation succeeded",
        "content": {
          "application/json": {
            "schema": {
              "type": "object"
            }
          }
        }
      },
      "BadRequest": {
        "description": "A client error has ocurred.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication missing or invalid",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Not authorized request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "InternalError": {
        "description": "A server error has ocurred."
      },
      "NotFound": {
        "description": "Item is not found",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string",
                  "example": "common.message.notFound"
                }
              }
            }
          }
        }
      },
      "RequestOrderItemSchemaResponse": {
        "description": "Request Order Item Schema",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/RequestOrderItemSchema"
            }
          }
        }
      }
    },
    "schemas": {
      "id": {
        "description": "The unique identifier of the item",
        "type": "string",
        "readOnly": true,
        "example": "631fb04c8fe08f51a8ee5949"
      },
      "status": {
        "description": "The item status",
        "type": "string",
        "default": "active",
        "enum": [
          "active",
          "inactive"
        ],
        "example": "active"
      },
      "dateCreated": {
        "description": "The date of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-12T19:00:00.000Z"
      },
      "dateModified": {
        "description": "The date of the last modification",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-20T19:00:00.000Z"
      },
      "dateCreatedDay": {
        "description": "The day of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-08-07T16:00:00.000Z"
      },
      "dateModifiedDay": {
        "description": "The day of last modification",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-08-07T16:00:00.000Z"
      },
      "userCreated": {
        "description": "The ID of the user who created the item",
        "type": "string",
        "readOnly": true,
        "example": "6a1fc1eeb5b68406e0487a10"
      },
      "userModified": {
        "description": "The ID of the user who last modified the item",
        "type": "string",
        "readOnly": true,
        "example": "7e1fc1eeb5b68406e048796"
      },
      "endpointParameters": {
        "type": "array",
        "description": "A list of endpoint parameters",
        "items": {
          "type": "object",
          "description": "An endpoint parameter to replace in the endpoint path or to send as data",
          "properties": {
            "name": {
              "type": "string",
              "description": "The name of the path or data parameter",
              "example": "status"
            },
            "target": {
              "type": "string",
              "description": "Where this parameter should be replaced.",
              "enum": [
                "queryString",
                "filter",
                "path",
                "body"
              ],
              "example": "queryString"
            },
            "value": {
              "oneOf": [
                {
                  "type": "object",
                  "description": "An static value",
                  "properties": {
                    "static": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "number"
                        },
                        {
                          "type": "array"
                        },
                        {
                          "type": "object"
                        },
                        {
                          "type": "boolean"
                        }
                      ],
                      "description": "Any static value you want to send",
                      "example": "active"
                    }
                  }
                },
                {
                  "type": "object",
                  "description": "A dynamic value",
                  "properties": {
                    "dynamic": {
                      "type": "string",
                      "description": "The name of the property you want to get the value from",
                      "example": "status"
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "endpoint": {
        "type": "object",
        "description": "The endpoint that should be called to execute the action",
        "properties": {
          "service": {
            "type": "string",
            "description": "The endpoint service name",
            "example": "delivery"
          },
          "namespace": {
            "type": "string",
            "description": "The endpoint namespace",
            "example": "shipping"
          },
          "method": {
            "type": "string",
            "description": "The endpoint method",
            "example": "patch"
          }
        }
      },
      "BaseAction": {
        "type": "object",
        "description": "An action that can be executed",
        "properties": {
          "kind": {
            "type": "string",
            "description": "A categorization of the action to help UI to group or organize the actions",
            "enum": [
              "generic"
            ],
            "example": "generic"
          },
          "name": {
            "type": "string",
            "description": "The action name",
            "example": "ConfirmCancellation"
          },
          "componentAttributes": {
            "type": "object",
            "description": "The componentAttributes of the action",
            "properties": {
              "icon": {
                "type": "string",
                "description": "The icon code associated to the action",
                "example": "cross_big_circle_bold"
              }
            }
          }
        }
      },
      "ActionWithForm": {
        "title": "Action with form",
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseAction"
          },
          {
            "properties": {
              "componentAttributes": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/BaseAction/properties/componentAttributes"
                  },
                  {
                    "properties": {
                      "endpoint": {
                        "$ref": "#/components/schemas/endpoint"
                      },
                      "endpointParameters": {
                        "$ref": "#/components/schemas/endpointParameters"
                      },
                      "fields": {
                        "type": "array",
                        "description": "The fields list that the user should see when executing this action",
                        "items": {
                          "type": "object",
                          "description": "A field schema",
                          "properties": {
                            "name": {
                              "type": "string",
                              "description": "The name of the field",
                              "example": "confirm"
                            },
                            "component": {
                              "type": "string",
                              "description": "The component that should be used for the field",
                              "example": "Checkbox"
                            }
                          }
                        }
                      }
                    }
                  },
                  {
                    "required": [
                      "fields",
                      "endpoint"
                    ]
                  }
                ]
              }
            }
          }
        ]
      },
      "ActionWithEndpoint": {
        "title": "Action with endpoint",
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseAction"
          },
          {
            "properties": {
              "componentAttributes": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/BaseAction/properties/componentAttributes"
                  },
                  {
                    "properties": {
                      "endpoint": {
                        "$ref": "#/components/schemas/endpoint"
                      },
                      "endpointParameters": {
                        "$ref": "#/components/schemas/endpointParameters"
                      }
                    }
                  },
                  {
                    "required": [
                      "endpoint"
                    ]
                  }
                ]
              }
            }
          }
        ],
        "required": [
          "kind",
          "name"
        ]
      },
      "ActionWithPath": {
        "title": "Action with path",
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseAction"
          },
          {
            "properties": {
              "componentAttributes": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/BaseAction/properties/componentAttributes"
                  },
                  {
                    "properties": {
                      "pathTarget": {
                        "type": "string",
                        "description": "Relative or Absolut Path to a domain.",
                        "example": "sac/claim/new"
                      },
                      "linkTarget": {
                        "type": "string",
                        "description": "The target attribute specifies where to open the linked document",
                        "example": "_blank"
                      },
                      "endpointParameters": {
                        "$ref": "#/components/schemas/endpointParameters"
                      },
                      "endpointTarget": {
                        "$ref": "#/components/schemas/endpoint"
                      }
                    }
                  },
                  {
                    "required": [
                      "pathTarget"
                    ]
                  }
                ]
              }
            }
          }
        ],
        "required": [
          "kind",
          "name"
        ]
      },
      "Flow": {
        "type": "object",
        "description": "A Flow",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "name": {
            "type": "string",
            "description": "The flow name",
            "example": "Refund of money"
          },
          "method": {
            "type": "string",
            "description": "The flow method",
            "enum": [
              "store",
              "home"
            ]
          },
          "type": {
            "type": "string",
            "description": "The flow request type",
            "enum": [
              "moneyRefund",
              "productRefundWithMoneyRefund",
              "productReplacementWithPriorReturn",
              "productReplacementWithoutPriorReturn"
            ]
          },
          "actions": {
            "type": "object",
            "description": "Actions to apply to the request or order",
            "properties": {
              "approve": {
                "type": "boolean",
                "description": "The request must be approved",
                "example": false
              },
              "picking": {
                "type": "boolean",
                "description": "The order must be picked",
                "example": false
              },
              "invoice": {
                "type": "boolean",
                "description": "The order must be invoiceable",
                "example": false
              },
              "creditNote": {
                "type": "boolean",
                "description": "A credit note must be added when returning money",
                "example": false
              },
              "allowStoreChange": {
                "type": "boolean",
                "description": "Determines a different store can be used for the request order or must use the original order one",
                "default": true,
                "example": true
              }
            }
          },
          "status": {
            "$ref": "#/components/schemas/status"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          },
          "userModified": {
            "$ref": "#/components/schemas/userModified"
          }
        },
        "required": [
          "id",
          "name",
          "requestType",
          "status",
          "dateCreated",
          "dateModified",
          "userCreated",
          "userModified"
        ]
      },
      "FlowList": {
        "type": "array",
        "description": "A list of Flows",
        "items": {
          "$ref": "#/components/schemas/Flow"
        }
      },
      "Request": {
        "type": "object",
        "description": "A Request",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "flowId": {
            "type": "string",
            "description": "ADD A DESCRIPTION",
            "example": "bar"
          },
          "orderId": {
            "type": "string",
            "description": "ADD A DESCRIPTION",
            "example": "bar"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          },
          "userModified": {
            "$ref": "#/components/schemas/userModified"
          }
        },
        "required": [
          "id",
          "flowId",
          "orderId",
          "dateCreated",
          "dateModified",
          "userCreated",
          "userModified"
        ]
      },
      "RequestList": {
        "type": "array",
        "description": "A list of Requests",
        "items": {
          "$ref": "#/components/schemas/Request"
        }
      },
      "RequestApproval": {
        "type": "object",
        "description": "An approval",
        "properties": {
          "comment": {
            "type": "string",
            "description": "A comment from the user that approved the request",
            "example": "Double checked"
          }
        }
      },
      "RefundItemsByRequest": {
        "type": "object",
        "description": "The items to refund",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "The item ID to return",
                  "example": "AEDD8C2CC2BE416E8364A372BC32A1AE"
                },
                "quantity": {
                  "type": "number",
                  "description": "The item quantity to return",
                  "example": 1
                }
              }
            }
          },
          "creditNoteNumber": {
            "type": "string",
            "description": "The Credit Note document number associated with the refund",
            "example": "CN-3094"
          },
          "rmaId": {
            "type": "string",
            "description": "The ID of the RMA that requested the refund",
            "example": "631fb04c8fe08f51a8ee5949"
          }
        }
      },
      "RequestRejection": {
        "type": "object",
        "description": "An rejection",
        "properties": {
          "comment": {
            "type": "string",
            "description": "A comment from the user that rejected the request",
            "example": "Not allowed"
          }
        }
      },
      "RequestOrderItemSchema": {
        "type": "object",
        "description": "A field schema",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the field",
            "example": "items"
          },
          "component": {
            "type": "string",
            "description": "The component that should be used for the field",
            "example": "Input"
          },
          "componentAttributes": {
            "type": "object",
            "description": "The component attributes",
            "example": {
              "type": "number"
            }
          }
        }
      }
    }
  }
}