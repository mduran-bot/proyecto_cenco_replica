      "get": {
        "x-janis-namespace": "link",
        "x-janis-method": "follow",
        "x-janis-permissions": [],
        "operationId": "followLink",
        "tags": [
          "Link"
        ],
        "summary": "Resolve a short link",
        "parameters": [
          {
            "name": "linkId",
            "in": "path",
            "schema": {
              "type": "string",
              "example": "a8s8f69"
            },
            "required": true,
            "description": "The short link ID"
          }
        ],
        "responses": {
          "301": {
            "$ref": "#/components/responses/followLink"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/short-link": {
      "post": {
        "x-janis-namespace": "short-link",
        "x-janis-method": "create",
        "x-janis-permissions": [
          "link:short-link:write"
        ],
        "operationId": "createShortLink",
        "tags": [
          "Link"
        ],
        "summary": "Create a Short Link",
        "security": [
          {
            "ApiKey": [],
            "ApiSecret": [],
            "JanisClient": []
          }
        ],
        "requestBody": {
          "description": "A link to be shortened",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShortLink"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A success request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "A Link",
                  "properties": {
                    "linkId": {
                      "description": "The identifier of the link registered in the DB",
                      "type": "string",
                      "example": "cxbwtc9"
                    },
                    "shortUrl": {
                      "description": "The shortened link",
                      "type": "string",
                      "example": "https://link.janisqa.in/api/l/cxbwtc9"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
