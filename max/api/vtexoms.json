          "importOrdersFulfillmentPackageBehaviour",
          "publishOrders",
          "usesOrderCustomerNote",
          "status",
          "dateCreated",
          "userCreated"
        ]
      },
      "Order": {
        "type": "object",
        "description": "An Order",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "accountId": {
            "type": "string",
            "description": "The Commerce Service Account id",
            "example": "6000798c6b464000084d8d40"
          },
          "commerceId": {
            "type": "string",
            "description": "The VTEX Order ID",
            "example": "1258752268211-01"
          },
          "orderGroupCommerceId": {
            "type": "string",
            "description": "The VTEX Order Group Commerce-ID",
            "example": "1258752268212-01"
          },
          "omsOrderGroupId": {
            "type": "string",
            "description": "The OMS Order Group ID",
            "example": "63124d9ddcd276d6edd992bf"
          },
          "omsOrderId": {
            "type": "string",
            "description": "The OMS Order ID",
            "example": "63124d9ddcd276d6edd992bd"
          },
          "totalAmount": {
            "type": "number",
            "description": "The Order original amount (removing rounding error)",
            "example": 150
          },
          "rawTotalAmount": {
            "type": "number",
            "description": "The Order original amount (including rounding error)",
            "example": 150
          },
          "receipts": {
            "type": "array",
            "description": "The invoice and item changes applied in VTEX order",
            "items": {
              "type": "object"
            },
            "example": [
              {
                "type": "invoice",
                "id": "15e0cac1-1a1c-40c7-af11-064ae2c48c9b",
                "date": "2022-09-02T18:54:46.128Z"
              },
              {
                "type": "change",
                "id": "15e0cac1-1a1c-40c7-af11-064ae2c48c9b",
                "date": "2022-09-02T18:54:46.128Z"
              }
            ]
          },
          "reservationIds": {
            "type": "array",
            "description": "Reservation ID created by Janis in VTEX",
            "items": {
              "type": "string",
              "example": "JAN-959431069122-01-1"
            }
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          },
          "userModified": {
            "$ref": "#/components/schemas/userModified"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          }
        }
      },
      "OrderList": {
        "type": "array",
        "description": "A list of Orders",
        "items": {
          "$ref": "#/components/schemas/Order"
        }
      },
      "DataDelivered": {
