      "OrderStatusChange": {
        "type": "object",
        "description": "An Order Status Change",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "source": {
            "type": "string",
            "description": "The source of the status change",
            "enum": [
              "vtex"
            ],
            "example": "vtex"
          },
          "orderId": {
            "type": "string",
            "description": "The VTEX ID of the order",
            "example": "46546546544-01"
          },
          "state": {
            "type": "string",
            "description": "The new state of the order",
            "example": "ready-for-handling"
          },
          "account": {
            "type": "string",
            "description": "The name of the VTEX account that originated the status change",
            "example": "fizzmod"
          },
          "vtexKey": {
            "type": "string",
            "description": "The VTEX APP Key that triggered the status change hook",
            "example": "vtexappkey-4as564564"
          },
          "statusChangeDate": {
            "type": "string",
            "description": "The date of the status change in VTEX",
            "example": "2021-06-22T20:36:19.008Z",
            "format": "date-time"
          },
          "loggingData": {
            "type": "array",
            "description": "A list of logging information of the status change process",
            "items": {
              "type": "string"
            },
            "example": [
              "Saved status change in DB",
              "Fetched order data from VTEX OMS"
            ]
          },
          "status": {
            "description": "The order status change processing status",
            "type": "string",
            "default": "pending",
            "enum": [
              "pending",
              "processing",
              "processed",
              "skipped",
              "error"
            ],
            "example": "pending"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          }
        },
        "required": [
          "id",
          "source",
          "orderId",
          "state",
          "account",
          "vtexKey",
          "statusChangeDate",
          "loggingData",
          "status",
          "dateCreated"
        ]
      },
      "OrderStatusChangeList": {
        "type": "array",
        "description": "A list of Order Status Changes",
        "items": {
          "$ref": "#/components/schemas/OrderStatusChange"
