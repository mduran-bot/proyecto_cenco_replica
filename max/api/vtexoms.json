          "id": {
            "type": "string",
            "description": "The `id` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "6000798c6b464000084d8d40"
          },
          "commerceId": {
            "type": "string",
            "description": "The VTEX Order ID. Refers to `commerceId` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "4354534545-01"
