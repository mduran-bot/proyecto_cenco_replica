            "type": "array",
            "description": "This setting will be used to determine which Actions will need not optional Motive",
            "items": {
              "type": "string",
              "description": "The action in {service}:{module}:{action} format",
              "example": "oms:order-refund:refund-items"
            },
            "example": [
              "oms:order-refund:refund-amount",
              "oms:order-refund:refund-items"
            ],
            "default": []
          }
        }
      },
      "listenerEvent": {
        "description": "A JANIS Event object",
        "type": "object",
        "properties": {
          "service": {
            "description": "The source service name",
            "type": "string",
            "example": "id"
          },
          "entity": {
            "description": "The event related entity",
            "type": "string",
            "example": "profile"
          },
          "event": {
            "description": "The event name",
            "type": "string",
            "example": "created"
          },
          "client": {
            "description": "The source event client",
            "type": "string",
            "example": "fizzmod"
          },
          "id": {
            "description": "The event related entity ID",
            "type": "string",
            "example": "5d699c1ae8ebb95eaa24aca9"
          }
        },
        "required": [
          "service",
          "entity",
          "event"
        ]
      },
      "FunctionError": {
        "type": "object",
        "properties": {
          "message": {
            "description": "The error message",
            "type": "string",
            "readOnly": true,
            "example": "Database Failed"
          }
        }
      },
      "FunctionTotals": {
        "type": "object",
        "description": "The totals data. It is only available when `calculateTotals` parameter is active",
        "properties": {
          "total": {
            "description": "The total items found in database applied filters",
            "type": "number",
            "readOnly": true,
            "example": 2
          },
          "pages": {
            "description": "The total pages for the filters applied",
            "type": "number",
            "readOnly": true,
            "example": 1
          },
          "page": {
            "description": "The actual page",
            "type": "number",
            "readOnly": true,
            "example": 1
          }
        }
      }
    }
  }
}