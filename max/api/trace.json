    "schemas": {
      "id": {
        "description": "The unique identifier of the item",
        "type": "string",
        "readOnly": true,
        "example": "d555345345345as67a342a"
      },
      "dateCreated": {
        "description": "The date of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-12T19:59:51.801Z"
      },
      "userCreated": {
        "description": "The ID of the user who created the item. This refer to the `id` of the **User** Entity of **Janis ID Service**. See [User](/v2/service/id#tag/User).",
        "type": "string",
        "readOnly": true,
        "example": "6a1fc1eeb5b68406e0487a10"
      },
      "serviceCreated": {
        "description": "The Janis Service Name who created the item.",
        "type": "string",
        "readOnly": true,
        "nullable": true,
        "example": "pricing"
      },
      "dateCreatedDay": {
        "description": "The date of creation",
        "type": "string",
        "format": "date-time",
        "example": "2019-07-12T19:59:51.801Z"
      },
      "Log": {
        "description": "A log",
        "type": "object",
        "properties": {
          "id": {
            "description": "The log ID (uuid format)",
            "type": "string",
            "example": "efe33996-37a2-458e-83ad-98ba1596b858"
          },
          "service": {
            "description": "The service where the log comes from",
            "type": "string",
            "example": "catalog"
          },
          "entity": {
            "description": "The entity of the service who created the log",
            "type": "string",
            "example": "product"
          },
          "entityId": {
            "description": "The entity ID (if exists)",
            "type": "string",
            "nullable": true,
            "example": "5f6b98ba1df718850eb64b9f"
          },
          "type": {
            "description": "The type of the log",
            "type": "string",
            "example": "created"
          },
          "message": {
            "description": "The log message",
            "type": "string",
            "nullable": true,
            "example": "The product was successfully created"
          },
          "log": {
            "description": "The log details (object when is a valid JSON, string otherwise)",
            "oneOf": [
              {
                "description": "The log details (when is a valid/parsable JSON string)",
                "type": "object",
                "example": {
                  "some": "data"
                }
              },
              {
                "description": "The log details (when is not a valid/parsable JSON string)",
                "type": "string",
                "example": "{'some':'data'}, {'broken': 'json'"
              }
            ]
          },
          "expirationDate": {
            "description": "The date of the expiration of the log",
            "type": "string",
            "format": "date-time",
            "readOnly": true,
            "example": "2020-09-07T16:03:52.000Z"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "userCreated": {
            "$ref": "#/components/schemas/userCreated"
          },
          "serviceCreated": {
            "$ref": "#/components/schemas/serviceCreated"
          },
          "insertDelay": {
            "description": "Represents the delay in **seconds** between the log creation date and its insertion date in the database.\n",
            "type": "number",
            "readOnly": true,
            "minimum": 0,
            "example": 80
          }
        },
        "required": [
          "service",
          "entity",
          "type"
        ]
      },
      "LogList": {
        "description": "A list of logs",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "$ref": "#/components/schemas/Log/properties/id"
