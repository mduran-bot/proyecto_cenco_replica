        "description": "The total amount of records in the list",
        "schema": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "responses": {
      "SuccessCreateResponse": {
        "description": "The item was created",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "$ref": "#/components/schemas/id"
                }
              }
            }
          }
        }
      },
      "SuccessUpdateResponse": {
        "description": "The item was updated",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "$ref": "#/components/schemas/id"
                }
              }
            }
          }
        }
      },
      "GenericSuccess": {
        "description": "Operation succeeded",
        "content": {
          "application/json": {
            "schema": {
              "type": "object"
            }
          }
        }
      },
      "BadRequest": {
        "description": "A client error has ocurred.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication missing or invalid",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Not authorized request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "InternalError": {
        "description": "A server error has ocurred."
      },
      "HookOrderStatusChange": {
        "description": "The status change was submitted",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number",
                  "description": "The status change id"
                }
              }
            }
          }
        }
      }
    },
    "schemas": {
      "id": {
        "description": "The unique identifier of the item",
        "type": "string",
        "readOnly": true,
        "example": "d555345345345as67a342a"
      },
      "status": {
        "description": "The item status",
        "type": "string",
        "default": "active",
        "enum": [
          "active",
          "inactive"
        ],
        "example": "active"
      },
      "dateCreated": {
        "description": "The date of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-12T19:00:00.000Z"
      },
      "dateModified": {
        "description": "The date of the last modification",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-20T19:00:00.000Z"
      },
      "dateCreatedDay": {
        "description": "The day of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-08-07T16:00:00.000Z"
      },
      "dateModifiedDay": {
        "description": "The day of last modification",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-08-07T16:00:00.000Z"
      },
      "dateCreatedRange": {
        "description": "Creation date range",
        "type": "object",
        "properties": {
          "from": {
            "allOf": [
              {
                "$ref": "#/components/schemas/dateCreated"
              }
            ],
            "description": "Date range from"
          },
          "to": {
            "allOf": [
              {
                "$ref": "#/components/schemas/dateCreated"
              }
            ],
            "description": "Date range to"
          }
        }
      },
      "dateModifiedRange": {
        "description": "Last modification date range",
        "type": "object",
        "properties": {
          "from": {
            "allOf": [
              {
                "$ref": "#/components/schemas/dateModified"
              }
            ],
            "description": "Date range from"
          },
          "to": {
            "allOf": [
              {
                "$ref": "#/components/schemas/dateModified"
              }
            ],
            "description": "Date range to"
          }
        }
      },
      "userCreated": {
        "description": "The ID of the user who created the item",
        "type": "string",
        "readOnly": true,
        "example": "6a1fc1eeb5b68406e0487a10"
      },
      "userModified": {
        "description": "The ID of the user who last modified the item",
        "type": "string",
        "readOnly": true,
        "example": "7e1fc1eeb5b68406e048796"
      },
      "Order": {
        "type": "object",
        "description": "An order",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "integrationOrderId": {
            "type": "string",
            "description": "The integration order id",
            "example": "V1StGXR8Z5jdHi6B"
          },
          "accountId": {
            "type": "string",
            "description": "The id of the account associated with the order",
            "example": "672cdadd1849404bde3d0c70"
          },
          "deliveryId": {
            "type": "string",
            "description": "The id associated with order shipping",
            "example": "672cdadd1849404bde3d0c80"
          },
          "accountName": {
            "type": "string",
            "description": "The name of the account associated with the order",
            "example": "fizzmodarg"
          },
          "status": {
            "description": "The order status",
            "type": "string",
            "enum": [
              "accepted",
              "cancelled"
            ],
            "example": "accepted"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          }
        },
        "required": [
          "id",
          "integrationOrderId",
          "accountId",
          "accountName",
          "status"
        ]
      },
      "OrderList": {
        "type": "array",
        "description": "A list of orders",
        "items": {
          "$ref": "#/components/schemas/Order"
        }
      },
      "DataDelivered": {
        "type": "object",
        "description": "Order data for inform to Magento that it is delivered",
        "properties": {
          "order": {
            "$ref": "#/components/schemas/OrderDelivered"
          }
        },
        "required": [
          "order"
        ]
      },
      "OrderDelivered": {
        "type": "object",
        "description": "Order data for inform to Magento that it is shipped",
        "properties": {
          "id": {
            "type": "string",
            "description": "The `id` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "6000798c6b464000084d8d40"
          },
          "commerceId": {
            "type": "string",
            "description": "The Magento Order ID. Refers to `commerceId` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "4354534545-01"
          },
          "orderGroupCommerceId": {
            "type": "string",
            "description": "The Magento Order Group Commerce-ID. Refers to `orderGroupCommerceId` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "4354534545"
          },
          "account": {
            "type": "object",
            "description": "The Account related to the Order",
            "properties": {
              "id": {
                "type": "string",
                "description": "The `id` of an **Account** in [Commerce Service](/v2/service/commerce#tag/Account)",
                "example": "6000798c6b464000084d8d40"
              }
            },
            "required": [
              "id"
            ]
          }
        },
        "required": [
          "id",
          "commerceId",
          "account"
        ]
      },
      "DataReadyForPickup": {
        "type": "object",
        "description": "The data of the order ready for pickup",
        "properties": {
          "order": {
            "$ref": "#/components/schemas/OrderReadyForPickup"
          }
        },
        "required": [
          "order"
        ]
      },
      "OrderReadyForPickup": {
        "type": "object",
        "description": "Order data for inform to Magento that it is ready for pickup",
        "properties": {
          "id": {
            "type": "string",
            "description": "The `id` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "6000798c6b464000084d8d40"
          },
          "commerceId": {
            "type": "string",
            "description": "The Magento Order ID. Refers to `commerceId` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "4354534545-01"
          },
          "orderGroupCommerceId": {
            "type": "string",
            "description": "The Magento Order Group Commerce-ID. Refers to `orderGroupCommerceId` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "4354534545"
          },
          "shipping": {
            "type": "object",
            "description": "The order's shipping to notify",
            "properties": {
              "isPickUp": {
                "type": "boolean",
                "description": "Indicates if the Shipping type is Pickup. The `isPickUp` of a `shipping` in an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
                "example": false
              }
            },
            "required": [
              "isPickUp"
            ]
          },
          "account": {
            "type": "object",
            "description": "The Account related to the Order",
            "properties": {
              "id": {
                "type": "string",
                "description": "The `id` of an **Account** in [Commerce Service](/v2/service/commerce#tag/Account)",
                "example": "6000798c6b464000084d8d40"
              }
            },
            "required": [
              "id"
            ]
          }
        },
        "required": [
          "id",
          "commerceId",
          "shipping",
          "account"
        ]
      },
      "DataShipped": {
        "type": "object",
        "description": "The data of the shipped order",
        "properties": {
          "order": {
            "$ref": "#/components/schemas/OrderShipped"
          },
          "trackingId": {
            "type": "string",
            "description": "The tracking number of the Shipping",
            "example": "771717172"
          },
          "trackingUrl": {
            "type": "string",
            "description": "The tracking URL of the Shipping",
            "example": "http://routeoftracking.com"
          }
        },
        "required": [
          "order"
        ]
      },
      "OrderShipped": {
        "type": "object",
        "description": "Order data for inform to Magento that it is shipped",
        "properties": {
          "id": {
            "type": "string",
            "description": "The `id` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "6000798c6b464000084d8d40"
          },
          "commerceId": {
            "type": "string",
            "description": "The Magento Order ID. Refers to `commerceId` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "4354534545-01"
          },
          "orderGroupCommerceId": {
            "type": "string",
            "description": "The Magento Order Group Commerce-ID. Refers to `orderGroupCommerceId` of an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
            "example": "4354534545"
          },
          "shipping": {
            "type": "object",
            "description": "The order's shipping to notify",
            "properties": {
              "companyName": {
                "type": "string",
                "description": "The `companyName` of a `shipping` in an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
                "example": "E-Delivery"
              },
              "isPickUp": {
                "type": "boolean",
                "description": "Indicates if the Shipping is Pickup Type. The `isPickUp` of a `shipping` in an **Order** in [OMS Service](/v2/service/oms#tag/Order)",
                "example": false
              },
              "warehouseId": {
                "type": "string",
                "description": "This refers to the `id` in the **Warehouse** Entity. See [Warehouse](/v2/service/wms#tag/Warehouse).",
                "example": "6b8bdac48ba45b0011913909"
              }
            },
            "required": [
              "companyName",
              "isPickUp"
            ]
          },
          "account": {
            "type": "object",
            "description": "The Account related to the Order",
            "properties": {
              "id": {
                "type": "string",
                "description": "The `id` of an **Account** in [Commerce Service](/v2/service/commerce#tag/Account)",
                "example": "6000798c6b464000084d8d40"
              }
            },
            "required": [
              "id"
            ]
          }
        },
        "required": [
          "id",
          "commerceId",
          "shipping",
          "account"
        ]
      },
      "OrderStatusChange": {
        "type": "object",
        "description": "An Order Status Change",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "source": {
            "type": "string",
            "description": "The source of the status change",
            "enum": [
              "magento"
            ],
            "example": "magento"
          },
          "orderId": {
            "type": "string",
            "description": "The Magento ID of the order",
            "example": "130"
          },
          "state": {
            "type": "string",
            "description": "The new state of the order",
            "example": "pending"
          },
          "account": {
            "type": "string",
            "description": "The name of the Magento account that originated the status change",
            "example": "fizzmod"
          },
          "externalRef": {
            "type": "string",
            "description": "An External Reference for the Order",
            "example": "000000024"
          },
          "stateMessage": {
            "type": "string",
            "description": "The State Explanation",
            "example": "A New Order"
          },
          "loggingData": {
            "type": "array",
            "description": "A list of logging information of the status change process",
            "readOnly": true,
            "items": {
              "type": "string"
            },
            "example": [
              "Saved status change in DB",
              "Fetched order data from Magento OMS"
            ]
          },
          "requestData": {
            "type": "object",
            "description": "The request data used when fetching data from Magento during the order status change process"
          },
          "requestResponse": {
            "type": "object",
            "description": "The response data used when fetching data from Magento during the order status change process"
          },
          "status": {
            "description": "The order status change processing status",
            "type": "string",
            "default": "pending",
            "enum": [
              "pending",
              "processing",
              "processed",
              "error"
            ],
            "example": "pending"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          }
        },
        "required": [
          "id",
          "orderId",
          "state",
          "account",
          "externalRef"
        ]
      },
      "OrderStatusChangeList": {
        "type": "array",
        "description": "A list of Order Status Changes",
        "items": {
          "$ref": "#/components/schemas/OrderStatusChange"
        }
      },
      "OrderStatusChangeHookItem": {
        "type": "object",
        "description": "A Magento order status change hook record",
        "properties": {
          "accountName": {
            "type": "string",
            "description": "The order's account name"
          },
          "orderId": {
            "type": "string",
            "description": "The Magento Order Incremental ID"
          },
          "externalRef": {
            "type": "string",
            "description": "The Magento Order External ID"
          },
          "status": {
            "type": "string",
            "description": "The current order status name"
          },
          "statusCode": {
            "type": "string",
            "description": "The current order status code"
          }
        },
        "required": [
          "accountName",
          "orderId",
          "externalRef",
          "status",
          "statusCode"
        ]
      },
      "listenerEvent": {
        "description": "A JANIS Event object",
        "type": "object",
        "properties": {
          "service": {
            "description": "The source service name",
            "type": "string",
            "example": "id"
          },
          "entity": {
            "description": "The event related entity",
            "type": "string",
            "example": "profile"
          },
          "event": {
            "description": "The event name",
            "type": "string",
            "example": "created"
          },
          "client": {
            "description": "The source event client",
            "type": "string",
            "example": "fizzmod"
          },
          "id": {
            "description": "The event related entity ID",
            "type": "string",
            "example": "5d699c1ae8ebb95eaa24aca9"
          }
        },
        "required": [
          "service",
          "entity",
          "event"
        ]
      }
    }
  }
}