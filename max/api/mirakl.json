    "responses": {
      "SuccessCreateResponse": {
        "description": "The item was created",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "$ref": "#/components/schemas/id"
                }
              }
            }
          }
        }
      },
      "SuccessUpdateResponse": {
        "description": "The item was updated",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "$ref": "#/components/schemas/id"
                }
              }
            }
          }
        }
      },
      "GenericSuccess": {
        "description": "Operation succeeded",
        "content": {
          "application/json": {
            "schema": {
              "type": "object"
            }
          }
        }
      },
      "BadRequest": {
        "description": "A client error has ocurred.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication missing or invalid",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Not authorized request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "description": "A message explaining the error",
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "InternalError": {
        "description": "A server error has ocurred."
      }
    },
    "schemas": {
      "id": {
        "description": "The unique identifier of the item",
        "type": "string",
        "readOnly": true,
        "example": "d555345345345as67a342a"
      },
      "status": {
        "description": "The item status",
        "type": "string",
        "default": "active",
        "enum": [
          "active",
          "inactive"
        ],
        "example": "active"
      },
      "dateCreated": {
        "description": "The date of creation",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-12T19:00:00.000Z"
      },
      "dateModified": {
        "description": "The date of the last modification",
        "type": "string",
        "format": "date-time",
        "readOnly": true,
        "example": "2019-07-20T19:00:00.000Z"
      },
      "import": {
        "type": "object",
        "description": "The Item's import properties",
        "properties": {
          "status": {
            "description": "The Item's import status",
            "readOnly": true,
            "type": "string",
            "enum": [
              "pending",
              "imported",
              "error"
            ],
            "example": "imported"
          },
          "startDate": {
            "description": "The Item's import start date",
            "readOnly": true,
            "type": "string",
            "format": "date-time",
            "example": "2022-12-09T18:44:50.637Z"
          },
          "endDate": {
            "description": "The Item's import end date",
            "readOnly": true,
            "type": "string",
            "format": "date-time",
            "example": "2022-12-09T18:44:50.637Z"
          },
          "errorMessage": {
            "description": "A message about the importation",
            "type": "string",
            "readOnly": true,
            "example": "Importation fails because .."
          }
        }
      },
      "dateRangeFilter": {
        "type": "object",
        "description": "A range for date. It will filter from 00:00Hs to 23:59:59Hs of the given range",
        "properties": {
          "from": {
            "type": "string",
            "description": "The beginning of the range",
            "format": "date-time",
            "example": "2019-11-27T16:08:24.994Z"
          },
          "to": {
            "type": "string",
            "description": "The end of the range",
            "format": "date-time",
            "example": "2019-11-30T16:08:24.994Z"
          }
        }
      },
      "AccountGet": {
        "type": "object",
        "description": "A Account",
        "allOf": [
          {
            "$ref": "#/components/schemas/AccountBase"
          }
        ],
        "properties": {
          "hasFrontKey": {
            "type": "boolean",
            "description": "if the account has access key to use in the integration",
            "example": false
          }
        },
        "required": [
          "integration",
          "urlBase",
          "hasFrontKey"
        ]
      },
      "AccountUpdate": {
        "type": "object",
        "description": "A Account",
        "allOf": [
          {
            "$ref": "#/components/schemas/AccountBase"
          }
        ],
        "properties": {
          "changeApiKey": {
            "type": "boolean",
            "description": "If the access key has been updated",
            "example": true
          },
          "frontKey": {
            "type": "string",
            "description": "Access key to use in the integration",
            "example": "45612AS321AS9ASOHFUH"
          }
        },
        "required": [
          "integration"
        ]
      },
      "AccountBase": {
        "type": "object",
        "description": "An account",
        "properties": {
          "integration": {
            "type": "boolean",
            "description": "If the integration is active",
            "example": true
          },
          "urlBase": {
            "type": "string",
            "description": "URL to use in the integration",
            "example": "https://example.mirakl.com/api"
          },
          "mapOrderItemDimensions": {
            "type": "boolean",
            "description": "Determines if it is necessary to map map order items dimensions with the Mirakl logistics dimensions",
            "example": true
          },
          "skipForSellers": {
            "type": "array",
            "description": "List of sellers to skip for Mirakl integration",
            "items": {
              "$ref": "#/components/schemas/id"
            }
          },
          "automaticCapturePostPicking": {
            "type": "boolean",
            "description": "Indicates if orders should automatically capture payments after picking",
            "example": true
          }
        }
      },
      "Location": {
        "description": "A Location from Mirakl",
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "commerceId": {
            "description": "The unique identifier of the [Location](/v2/service/commerce#tag/Location) in Commerce Service",
            "type": "string",
            "example": "f555345345345as67a3400"
          },
          "miraklId": {
            "description": "The Location's Mirakl ID. It is the same ID from the Seller",
            "type": "string",
            "readOnly": true,
            "example": "20"
          },
          "name": {
            "description": "The Location name",
            "type": "string",
            "readOnly": true,
            "example": "Bruce Wayne"
          },
          "latitude": {
            "description": "Location's latitude",
            "type": "number",
            "example": -34.5864066
          },
          "longitude": {
            "description": "Location's longitude",
            "type": "number",
            "example": -58.4321807
          },
          "address": {
            "$ref": "#/components/schemas/LocationAddress"
          },
          "status": {
            "$ref": "#/components/schemas/status"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          },
          "import": {
            "$ref": "#/components/schemas/import"
          }
        }
      },
      "LocationAddress": {
        "description": "Address Information of the Location",
        "type": "object",
        "properties": {
          "country": {
            "type": "string",
            "description": "The country of the location",
            "example": "URY"
          },
          "city": {
            "type": "string",
            "description": "The city of the location",
            "example": "Montevideo"
          },
          "neighborhood": {
            "type": "string",
            "description": "The neighborhood of the location",
            "example": "Centro"
          },
          "street": {
            "type": "string",
            "description": "The street of the location",
            "example": "Av. Italia"
          },
          "number": {
            "type": "string",
            "description": "The street's number of the location",
            "example": "5555"
          },
          "phone": {
            "type": "string",
            "description": "The phone's number of the location",
            "example": "1544445555"
          },
          "email": {
            "type": "string",
            "description": "The email of the location",
            "example": "depot@wayne-company.com"
          },
          "postalCode": {
            "type": "string",
            "description": "The postal code of the location",
            "example": "10000"
          }
        }
      },
      "LocationList": {
        "description": "The list data",
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Location"
        }
      },
      "LogisticsDimension": {
        "type": "object",
        "description": "A Logistics Dimension",
        "properties": {
          "code": {
            "type": "string",
            "description": "Logistics code",
            "example": "large"
          },
          "weight": {
            "type": "number",
            "description": "The weight for mapping in this code",
            "example": 15
          },
          "height": {
            "type": "number",
            "description": "The height for mapping in this code",
            "example": 15
          },
          "width": {
            "type": "number",
            "description": "The width for mapping in this code",
            "example": 15
          },
          "length": {
            "type": "number",
            "description": "The length for mapping in this code",
            "example": 15
          }
        },
        "required": [
          "code",
          "weight",
          "height",
          "width",
          "length"
        ]
      },
      "LogisticsDimensionList": {
        "type": "array",
        "description": "A list of Logistics Dimensions",
        "items": {
          "$ref": "#/components/schemas/LogisticsDimension"
        }
      },
      "OMSOrderHookNotification": {
        "type": "object",
        "description": "A notification for an Order Hook from Janis OMS",
        "properties": {
          "order": {
            "type": "object",
            "description": "An [OMS Order](/v2/service/oms#operation/getOrder). See full example there",
            "example": {
              "id": "d555345345345as67a342a",
              "commerceId": "4354534545-01",
              "status": "new"
            }
          },
          "taskToken": {
            "type": "string",
            "description": "A token to notify when task succeeds or fails"
          }
        }
      },
      "Seller": {
        "description": "A Seller from Mirakl",
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "omsId": {
            "description": "The unique identifier of the [Seller](/v2/service/oms#tag/Seller) in OMS Service",
            "type": "string",
            "example": "f555345345345as67a3400"
          },
          "miraklId": {
            "description": "The Seller's Mirakl ID",
            "type": "string",
            "readOnly": true,
            "example": "20"
          },
          "name": {
            "description": "The Seller name",
            "type": "string",
            "readOnly": true,
            "example": "Bruce Wayne"
          },
          "email": {
            "description": "The Seller email",
            "type": "string",
            "readOnly": true,
            "example": "bruce.wayne@wayne-company.com"
          },
          "logoUrl": {
            "description": "The Seller logo's URL",
            "type": "string",
            "readOnly": true,
            "example": "https://image.wayne-company.com.goth/public/ceo.png"
          },
          "phone": {
            "description": "The Seller phone",
            "type": "string",
            "readOnly": true,
            "example": "1544445556"
          },
          "status": {
            "$ref": "#/components/schemas/status"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          },
          "import": {
            "$ref": "#/components/schemas/import"
          }
        }
      },
      "SellerList": {
        "description": "The list data",
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Seller"
        }
      },
      "Warehouse": {
        "description": "A Warehouse from Mirakl",
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/id"
          },
          "wmsId": {
            "description": "The unique identifier of the [Warehouse](/v2/service/wms#tag/Warehouse) in Commerce Service",
            "type": "string",
            "example": "f555345345345as67a3400"
          },
          "miraklId": {
            "description": "The Warehouse's Mirakl ID. It is the same ID from the Seller",
            "type": "string",
            "readOnly": true,
            "example": "20"
          },
          "name": {
            "description": "The Warehouse name",
            "type": "string",
            "readOnly": true,
            "example": "Bruce Wayne"
          },
          "salesChannels": {
            "description": "A list with Warehouse Sales Channels IDs. This refer to the `id` of the **SalesChannel** Entity. See [SalesChannels](/v2/service/commerce#tag/Sales-Channel).",
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "5fa2f817bf7350096e71e2c8",
              "60d5bb1fbc650100142b835e"
            ],
            "readOnly": true
          },
          "limitedToSellers": {
            "description": "The Sellers to limit the Warehouse usage. This refer to the `id` of the [Sellers](/v2/service/oms#tag/Seller) in OMS Service.",
            "type": "array",
            "items": {
              "type": "string",
              "example": "6085bfd1ce5a1a0007a0dd00"
            },
            "readOnly": true
          },
          "locationCommerceId": {
            "description": "The unique identifier of the [Location](/v2/service/commerce#tag/Location) in Commerce Service, where the Warehouse belongs",
            "type": "string",
            "example": "f555345345345as67a3400"
          },
          "status": {
            "$ref": "#/components/schemas/status"
          },
          "dateCreated": {
            "$ref": "#/components/schemas/dateCreated"
          },
          "dateModified": {
            "$ref": "#/components/schemas/dateModified"
          },
          "import": {
            "$ref": "#/components/schemas/import"
          }
        }
      },
      "WarehouseList": {
        "description": "The list data",
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Warehouse"
        }
      },
      "listenerEvent": {
        "description": "A JANIS Event object",
