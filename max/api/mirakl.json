                  }
                ],
                "example": "delivered"
              }
            }
          }
        ]
      },
      "deliveryShippingStartedListener": {
        "allOf": [
          {
            "$ref": "#/components/schemas/deliveryShippingListenerBase"
          },
          {
            "properties": {
              "event": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/deliveryListenerEventBase/properties/event"
                  }
                ],
                "example": "started"
              }
            }
          }
        ]
      },
